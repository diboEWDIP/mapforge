const KEY_ICON_BOX_W      = 46;  // x-space reserved for icon per row
const KEY_ICON_LABEL_GAP  = 10;  // gap between icon box edge and label text
const KEY_COL_MARGIN      = 18;  // extra right-padding added after each column's widest label
const KEY_ROW_H           = 46;  // row height
