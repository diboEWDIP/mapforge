<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <title>MapForge — InquiryForge</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@400;600&display=swap" rel="stylesheet">
  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      background: #a89878;
      font-family: Georgia, serif;
      display: flex;
      flex-direction: column;
      height: 100vh;
      overflow: hidden;
    }

    /* ── Toolbar ── */
    #toolbar {
      display: flex;
      flex-direction: column;
      padding: 0 16px;
      background: #28200f;
      width: 100%;
      border-bottom: 2px solid #8a6a28;
    }
    .toolbar-row {
      display: flex;
      align-items: center;
      gap: 6px;
      padding: 5px 0;
      flex-wrap: nowrap;
      overflow-x: auto;
      scrollbar-width: thin;
      scrollbar-color: #6a5020 #28200f;
    }
    .toolbar-row::-webkit-scrollbar { height: 4px; }
    .toolbar-row::-webkit-scrollbar-track { background: #28200f; }
    .toolbar-row::-webkit-scrollbar-thumb { background: #6a5020; border-radius: 2px; }
    .toolbar-row + .toolbar-row {
      border-top: 1px solid #3e3018;
    }
    #toolbar span.lbl {
      color: #c8a048;
      font-size: 10px;
      letter-spacing: 1.5px;
      text-transform: uppercase;
      flex-shrink: 0;
    }
    .sep { color: #5a4020; font-size: 20px; flex-shrink: 0; }

    .stamp-btn {
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      gap: 0;
      padding: 5px 8px;
      background: linear-gradient(180deg, #3e3220 0%, #2e2415 100%);
      border: 1.5px solid #8a6a38;
      border-radius: 7px;
      cursor: pointer;
      color: #e8d8a8;
      font-size: 10px;
      font-family: Georgia, serif;
      flex-shrink: 0;
      transition: background 0.12s, border-color 0.12s, color 0.12s, box-shadow 0.12s;
      position: relative;
    }
    /* Tooltip */
    .stamp-btn[title]:hover::after {
      content: attr(title);
      position: absolute;
      bottom: calc(100% + 6px);
      left: 50%;
      transform: translateX(-50%);
      background: #180e04;
      color: #e8d8a8;
      font-family: Georgia, serif;
      font-size: 10px;
      white-space: nowrap;
      padding: 3px 7px;
      border-radius: 5px;
      border: 1px solid #5a4020;
      pointer-events: none;
      z-index: 9999;
      letter-spacing: 0.3px;
    }
    .stamp-btn[title]:hover::before {
      content: '';
      position: absolute;
      bottom: calc(100% + 1px);
      left: 50%;
      transform: translateX(-50%);
      border: 5px solid transparent;
      border-top-color: #5a4020;
      pointer-events: none;
      z-index: 9999;
    }
    .stamp-btn:hover  {
      background: linear-gradient(180deg, #504030 0%, #3e3020 100%);
      border-color: #c8a048;
      color: #fff;
    }
    .stamp-btn.active {
      background: linear-gradient(180deg, #a06018 0%, #7a4410 100%);
      border-color: #e0a030;
      color: #fff;
      box-shadow: 0 0 10px rgba(200, 140, 30, 0.4);
    }
    .stamp-btn canvas { display: block; }

    .color-btn {
      width: 24px; height: 24px;
      border-radius: 50%;
      border: 2px solid #8a6a38;
      cursor: pointer;
      flex-shrink: 0;
      transition: border-color 0.12s, transform 0.1s, box-shadow 0.12s;
      box-shadow: 0 1px 4px rgba(0,0,0,0.5);
    }
    .color-btn:hover  { border-color: #e0c060; transform: scale(1.18); }
    .color-btn.active { border-color: #fff; box-shadow: 0 0 0 2px #c8a030, 0 1px 4px rgba(0,0,0,0.5); }

    /* Font size controls */
    .size-ctrl {
      display: flex;
      align-items: center;
      gap: 4px;
      flex-shrink: 0;
    }
    .size-ctrl button {
      background: linear-gradient(180deg, #3e3220 0%, #2e2415 100%);
      border: 1.5px solid #8a6a38; border-radius: 5px;
      color: #e8d8a8; font-size: 14px; font-family: Georgia, serif;
      width: 26px; height: 26px; cursor: pointer; line-height: 1;
      transition: background 0.12s, border-color 0.12s;
    }
    .size-ctrl button:hover { background: linear-gradient(180deg, #504030 0%, #3e3020 100%); border-color: #c8a048; }
    #font-size-display {
      min-width: 28px; text-align: center; color: #e8d8a8; font-size: 12px;
    }

    /* Font style toggle (lives inside #text-ctrl, always flex when visible) */
    #font-style-ctrl {
      display: flex;
      align-items: center;
      gap: 4px;
      flex-shrink: 0;
    }
    .font-style-btn {
      padding: 3px 9px;
      background: linear-gradient(180deg, #3e3220 0%, #2e2415 100%);
      border: 1.5px solid #8a6a38;
      border-radius: 5px;
      color: #e8d8a8;
      font-size: 12px;
      font-family: Georgia, serif;
      cursor: pointer;
      line-height: 1.4;
      transition: background 0.12s, border-color 0.12s;
    }
    .font-style-btn:hover  { background: linear-gradient(180deg, #504030 0%, #3e3020 100%); border-color: #c8a048; color: #fff; }
    .font-style-btn.active { background: linear-gradient(180deg, #a06018 0%, #7a4410 100%); border-color: #e0a030; color: #fff; box-shadow: 0 0 8px rgba(200,140,30,0.4); }

    /* Shade controls (inside #shade-ctrl wrapper) */
    #shade-ctrl input[type=range] {
      width: 80px;
      cursor: pointer;
      accent-color: #c8a030;
    }
    #shade-ctrl .lbl { white-space: nowrap; }
    .shade-style-btn {
      padding: 3px 8px;
      background: linear-gradient(180deg, #3e3220 0%, #2e2415 100%);
      border: 1.5px solid #8a6a38;
      border-radius: 5px;
      color: #e8d8a8;
      font-size: 10px;
      font-family: Georgia, serif;
      cursor: pointer;
      line-height: 1.4;
      transition: background 0.12s, border-color 0.12s;
    }
    .shade-style-btn:hover  { background: linear-gradient(180deg, #504030 0%, #3e3020 100%); border-color: #c8a048; color: #fff; }
    .shade-style-btn.active { background: linear-gradient(180deg, #a06018 0%, #7a4410 100%); border-color: #e0a030; color: #fff; box-shadow: 0 0 8px rgba(200,140,30,0.4); }

    /* Stamp size control (inside #stamp-size-ctrl wrapper) */
    #stamp-size-ctrl input[type=range] {
      width: 80px;
      cursor: pointer;
      accent-color: #c8a030;
    }
    #stamp-size-ctrl .lbl { white-space: nowrap; }

    /* ── Canvas area ── */
    /* ── Main area (toolbar below, sidebars + map) ── */
    #main-area {
      display: flex;
      flex: 1;
      min-height: 0;
      overflow: hidden;
    }

    /* ── Left sidebar — Label panel always visible ── */
    #sidebar-left {
      width: 164px;
      flex-shrink: 0;
      background: #ede5d0;
      border-right: 2px solid #c8a030;
      overflow-y: auto;
      overflow-x: hidden;
    }

    /* ── Right sidebar — Features / Religion / Trade always visible ── */
    #sidebar-right {
      width: 196px;
      flex-shrink: 0;
      background: #ede5d0;
      border-left: 2px solid #c8a030;
      overflow-y: auto;
      overflow-x: hidden;
    }
    .sr-section-header {
      color: #7a5c1e;
      font-family: Georgia, serif;
      font-size: 9px;
      letter-spacing: 1.8px;
      text-transform: uppercase;
      text-align: center;
      padding: 8px 8px 5px;
      border-bottom: 1px solid #d4b870;
      margin-bottom: 6px;
    }

    #canvas-wrap {
      flex: 1;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 16px;
      min-height: 0;
      min-width: 0;
      position: relative;
    }

    /* ── Feature panel ── */
    #feature-panel {
      display: block;
      padding: 0 8px 10px;
    }

    /* ── Religion panel ── */
    #religion-panel {
      display: block;
      padding: 0 8px 10px;
    }
    .religion-panel-title {
      color: #7a5c1e;
      font-size: 10px;
      letter-spacing: 1.5px;
      text-transform: uppercase;
      text-align: center;
      margin-bottom: 8px;
      border-bottom: 1px solid #d4b870;
      padding-bottom: 6px;
    }
    .religion-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 6px;
    }
    .religion-btn {
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      text-align: center;
      gap: 3px;
      padding: 6px 4px;
      background: #faf5ea;
      border: 1.5px solid #c8a030;
      border-radius: 7px;
      cursor: pointer;
      color: #2a1f0e;
      font-size: 9px;
      font-family: Georgia, serif;
      transition: background 0.12s, border-color 0.12s, box-shadow 0.12s;
    }
    .religion-btn:hover  { background: #e8d8a0; border-color: #8a5808; color: #2a1f0e; }
    .religion-btn.active { background: linear-gradient(180deg, #a06810 0%, #7a4c08 100%); border-color: #c8a030; color: #fff; box-shadow: 0 0 8px rgba(160,100,20,0.3); }

    .feature-panel-title {
      color: #7a5c1e;
      font-size: 10px;
      letter-spacing: 1.5px;
      text-transform: uppercase;
      text-align: center;
      margin-bottom: 8px;
      border-bottom: 1px solid #d4b870;
      padding-bottom: 6px;
    }

    .feature-grid {
      display: flex;
      flex-direction: column;
      gap: 6px;
    }

    .feature-btn {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 3px;
      padding: 6px 4px;
      background: #faf5ea;
      border: 1.5px solid #c8a030;
      border-radius: 7px;
      cursor: pointer;
      color: #2a1f0e;
      font-size: 9px;
      font-family: Georgia, serif;
      transition: background 0.12s, border-color 0.12s, box-shadow 0.12s;
    }
    .feature-btn:hover  { background: #e8d8a0; border-color: #8a5808; color: #2a1f0e; }
    .feature-btn.active { background: linear-gradient(180deg, #a06810 0%, #7a4c08 100%); border-color: #c8a030; color: #fff; box-shadow: 0 0 8px rgba(160,100,20,0.3); }

    /* ── Trade panel ── */
    #trade-panel {
      display: block;
      padding: 0 8px 10px;
    }

    .trade-panel-title {
      color: #7a5c1e;
      font-size: 10px;
      letter-spacing: 1.5px;
      text-transform: uppercase;
      text-align: center;
      margin-bottom: 8px;
      border-bottom: 1px solid #d4b870;
      padding-bottom: 6px;
    }

    .trade-grid {
      display: grid;
      grid-template-columns: 1fr 1fr 1fr;
      gap: 5px;
    }

    .trade-btn {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 2px;
      padding: 4px 2px;
      background: #faf5ea;
      border: 1.5px solid #c8a030;
      border-radius: 6px;
      cursor: pointer;
      color: #2a1f0e;
      font-size: 8px;
      font-family: Georgia, serif;
      transition: background 0.12s, border-color 0.12s, box-shadow 0.12s;
    }
    .trade-btn:hover  { background: #e8d8a0; border-color: #8a5808; color: #2a1f0e; }
    .trade-btn.active { background: linear-gradient(180deg, #a06810 0%, #7a4c08 100%); border-color: #c8a030; color: #fff; box-shadow: 0 0 8px rgba(160,100,20,0.3); }

    /* Wrapper shrinks to fit the canvas — sized by JS */
    #map-wrapper {
      position: relative;
      display: inline-flex;
      box-shadow: 0 4px 24px rgba(0,0,0,0.6);
    }

    #map-canvas {
      display: block;
      cursor: crosshair;
    }
    #map-canvas.shade-active { cursor: none; }
    #map-canvas.eraser-active { cursor: cell; }

    /* Shade brush cursor preview */
    #shade-cursor {
      position: absolute;
      border-radius: 50%;
      border: 2px solid rgba(0,0,0,0.55);
      pointer-events: none;
      display: none;
      transform: translate(-50%, -50%);
      box-sizing: border-box;
      background: transparent;
      z-index: 10;
    }

    /* ── Map Key Modal ── */
    #key-modal-overlay {
      display: none;
      position: fixed;
      inset: 0;
      background: rgba(40,20,5,0.55);
      z-index: 500;
      align-items: center;
      justify-content: center;
    }
    #key-modal-overlay.open { display: flex; }
    #key-modal {
      background: #ede5d0;
      border: 2px solid #c8a030;
      border-radius: 12px;
      padding: 20px 24px;
      width: 400px;
      box-shadow: 0 6px 32px rgba(40,20,5,0.4);
      color: #2a1f0e;
      font-family: Georgia, serif;
    }
    #key-modal h3 {
      color: #7a5c1e;
      font-size: 12px;
      letter-spacing: 1.5px;
      text-transform: uppercase;
      text-align: center;
      margin-bottom: 14px;
      border-bottom: 1px solid #d4b870;
      padding-bottom: 8px;
    }
    .km-row {
      display: flex;
      align-items: center;
      gap: 8px;
      margin-bottom: 10px;
      flex-wrap: wrap;
    }
    .km-lbl {
      color: #7a5c1e;
      font-size: 10px;
      letter-spacing: 1px;
      text-transform: uppercase;
      min-width: 46px;
      flex-shrink: 0;
    }
    .km-type-btn, .km-style-btn {
      padding: 3px 12px;
      background: #faf5ea;
      border: 1.5px solid #c8a030;
      border-radius: 6px;
      color: #2a1f0e;
      font-size: 10px;
      font-family: Georgia, serif;
      cursor: pointer;
      transition: background 0.12s, border-color 0.12s;
    }
    .km-type-btn:hover, .km-style-btn:hover { background: #e8d8a0; border-color: #8a5808; }
    .km-type-btn.active {
      background: linear-gradient(180deg, #a06810 0%, #7a4c08 100%);
      border-color: #c8a030; color: #fff;
    }
    .km-style-btn.active {
      background: linear-gradient(180deg, #a06810 0%, #7a4c08 100%);
      border-color: #c8a030; color: #fff;
    }
    .km-color-btn {
      width: 20px; height: 20px;
      border-radius: 50%;
      border: 2px solid #c8a030;
      cursor: pointer;
      flex-shrink: 0;
      transition: border-color 0.12s, transform 0.1s;
    }
    .km-color-btn:hover  { border-color: #8a5808; transform: scale(1.15); }
    .km-color-btn.active { border-color: #2a1f0e; box-shadow: 0 0 0 2px #c8a030; }
    .km-input {
      flex: 1;
      background: #faf5ea;
      border: 1.5px solid #c8a030;
      border-radius: 5px;
      color: #2a1f0e;
      font-size: 12px;
      font-family: Georgia, serif;
      padding: 4px 8px;
      outline: none;
    }
    .km-input:focus { border-color: #8a5808; }
    .km-actions {
      display: flex;
      justify-content: center;
      gap: 10px;
      margin-top: 14px;
    }
    .km-btn {
      padding: 6px 20px;
      border-radius: 7px;
      font-size: 12px;
      font-family: Georgia, serif;
      cursor: pointer;
      border: 1.5px solid;
      transition: background 0.12s;
    }
    .km-btn.primary   { background: linear-gradient(180deg, #a06810 0%, #7a4c08 100%); border-color: #c8a030; color: #fff; }
    .km-btn.primary:hover { background: linear-gradient(180deg, #b87818 0%, #8a5810 100%); }
    .km-btn.secondary { background: #faf5ea; border-color: #c8a030; color: #2a1f0e; }
    .km-btn.secondary:hover { background: #e8d8a0; border-color: #8a5808; }
    #km-addmore { text-align: center; padding: 10px 0; }
    #km-addmore p { font-size: 13px; color: #2a1f0e; margin-bottom: 14px; }

    .km-tabs { display: flex; gap: 5px; margin-bottom: 14px; }
    .km-tab {
      flex: 1; padding: 5px 10px;
      background: #faf5ea;
      border: 1.5px solid #c8a030; border-radius: 6px;
      color: #2a1f0e; font-size: 11px; font-family: Georgia, serif; cursor: pointer;
    }
    .km-tab:hover { background: #e8d8a0; border-color: #8a5808; }
    .km-tab.active { background: linear-gradient(180deg, #a06810 0%, #7a4c08 100%); border-color: #c8a030; color: #fff; }
    .km-edit-list {
      max-height: 190px; overflow-y: auto;
      border: 1px solid #d4b870; border-radius: 5px;
      padding: 4px; margin-bottom: 10px;
      scrollbar-width: thin; scrollbar-color: #c8a030 #ede5d0;
    }
    .km-edit-row {
      display: flex; align-items: center; gap: 8px;
      padding: 5px 8px; border-radius: 4px; cursor: pointer; user-select: none;
    }
    .km-edit-row:hover { background: #e4d8bc; }
    .km-edit-row input[type=checkbox] { cursor: pointer; accent-color: #c8a030; flex-shrink: 0; }
    .km-edit-row .km-label-input {
      flex: 1; background: #faf5ea; border: 1px solid #d4b870; border-radius: 4px;
      color: #2a1f0e; font-size: 11px; font-family: Georgia, serif;
      padding: 2px 6px; outline: none; min-width: 0;
    }
    .km-edit-row .km-label-input:focus { border-color: #8a5808; }
    #km-remove-btn:disabled { opacity: 0.4; cursor: default; }
    #title-modal-overlay {
      display: none; position: fixed; inset: 0;
      background: rgba(40,20,5,0.55); z-index: 500;
      align-items: center; justify-content: center;
    }
    #title-modal-overlay.open { display: flex; }
    #title-modal {
      background: #ede5d0; border: 2px solid #c8a030; border-radius: 12px;
      padding: 20px 24px; width: 380px;
      box-shadow: 0 6px 32px rgba(40,20,5,0.4); font-family: Georgia, serif;
    }
    #title-modal h3 { color: #7a5c1e; font-size: 12px; letter-spacing: 1.5px; text-transform: uppercase; text-align: center; margin-bottom: 8px; border-bottom: 1px solid #d4b870; padding-bottom: 8px; }
    #title-current { color: #5a4020; font-size: 11px; text-align: center; margin-bottom: 12px; font-style: italic; }

    /* ── On-map draggable title box ── */
    #title-box {
      display: none;
      position: absolute;
      background: #faf6ee;
      border: 2.5px solid #111;
      padding: 5px 16px 6px;
      font-family: Georgia, serif;
      font-size: clamp(13px, 1.8vw, 22px);
      font-weight: bold;
      color: #111;
      white-space: nowrap;
      cursor: move;
      user-select: none;
      pointer-events: auto;
      z-index: 50;
      box-shadow: 2px 2px 8px rgba(0,0,0,0.25);
      transform: translateX(-50%);
    }
    #title-box.visible { display: block; }

    /* ── Start screen ── */
    #start-screen {
      position: fixed; inset: 0; z-index: 1000;
      background: linear-gradient(160deg, #e8e0d0 0%, #f2ead8 60%, #e4d8c0 100%);
      display: flex; flex-direction: column; align-items: center;
      overflow-y: auto; padding: 48px 24px 56px; box-sizing: border-box;
      transition: opacity 0.3s;
    }
    /* Subtle map-grid overlay on the landing screen */
    #start-screen::before {
      content: '';
      position: fixed; inset: 0; pointer-events: none; z-index: 0;
      background-image:
        linear-gradient(rgba(90,70,30,0.06) 1px, transparent 1px),
        linear-gradient(90deg, rgba(90,70,30,0.06) 1px, transparent 1px);
      background-size: 48px 48px;
    }
    #start-screen > * { position: relative; z-index: 1; }

    #ss-header { text-align: center; margin-bottom: 44px; }
    #ss-header h1 {
      font-family: 'Cinzel', Georgia, serif; font-size: 42px; font-weight: 600;
      color: #2a1f0e; letter-spacing: 5px; margin: 0 0 4px;
    }
    #ss-tagline {
      font-family: Georgia, serif; font-size: 13px; font-style: italic;
      color: #7a5c1e; margin: 0 0 10px; letter-spacing: 1px;
    }
    #ss-header > p:last-child {
      font-family: Georgia, serif; font-size: 13px; color: #5a4a30; margin: 0;
    }
    /* Decorative rule under the header */
    #ss-header-rule {
      display: flex; align-items: center; gap: 10px;
      margin: 14px auto 0; width: fit-content;
    }
    #ss-header-rule span { display: block; height: 1px; width: 80px; background: #b8903a; opacity: 0.6; }
    #ss-header-rule svg { flex-shrink: 0; }

    #ss-choices {
      display: flex; gap: 20px; margin-bottom: 40px; flex-wrap: wrap;
      justify-content: center; align-items: stretch;
    }
    .ss-choice, .ss-choice-primary {
      background: #faf5ea;
      border: 1.5px solid #c8a030;
      border-radius: 14px;
      padding: 30px 32px 28px; width: 220px; text-align: center; cursor: pointer;
      transition: border-color 0.15s, background 0.15s, transform 0.18s, box-shadow 0.18s;
      display: flex; flex-direction: column; align-items: center; text-decoration: none;
      box-shadow: 0 2px 8px rgba(100,70,10,0.10), 0 0 0 0 rgba(180,130,30,0);
    }
    .ss-choice-primary {
      border-color: #a06810;
      background: #fffbf0;
      box-shadow: 0 4px 18px rgba(100,70,10,0.15);
    }
    .ss-choice:hover, .ss-choice-primary:hover {
      border-color: #8a5808;
      background: #fffcf2;
      transform: translateY(-4px);
      box-shadow: 0 8px 28px rgba(100,70,10,0.18);
    }
    .ss-choice-icon {
      width: 52px; height: 52px; margin-bottom: 16px;
      display: flex; align-items: center; justify-content: center;
    }
    .ss-choice-title {
      color: #2a1f0e; font-family: 'Cinzel', Georgia, serif;
      font-size: 15px; font-weight: 600; letter-spacing: 0.5px;
      margin-bottom: 9px;
    }
    .ss-choice-desc { color: #5a4a30; font-family: Georgia, serif; font-size: 12px; line-height: 1.6; }
    .ss-disclaimer {
      color: #8a7a5a; font-family: Georgia, serif; font-size: 10px;
      font-style: italic; margin-top: 12px; line-height: 1.5; max-width: 180px;
    }
    #ss-library { width: 100%; max-width: 1200px; }
    #ss-back {
      display: inline-block; margin-bottom: 20px; color: #8a5808;
      font-family: Georgia, serif; font-size: 13px; cursor: pointer; user-select: none;
    }
    #ss-back:hover { color: #2a1f0e; }
    #ss-library-grid {
      display: grid; grid-template-columns: repeat(auto-fill, minmax(220px, 1fr)); gap: 18px;
    }
    .ss-section-header {
      grid-column: 1 / -1;
      color: #7a5c1e; font-family: 'Cinzel', Georgia, serif; font-size: 10px;
      letter-spacing: 2.5px; text-transform: uppercase;
      padding: 6px 0 8px; border-bottom: 1px solid #c8a030;
      margin-top: 8px;
    }
    .ss-section-header:first-child { margin-top: 0; }
    .ss-map-card {
      background: #faf5ea; border: 1.5px solid #d4b870; border-radius: 10px;
      overflow: hidden; cursor: pointer; transition: border-color 0.15s, transform 0.15s, box-shadow 0.15s;
      box-shadow: 0 2px 6px rgba(100,70,10,0.08);
    }
    .ss-map-card:hover { border-color: #8a5808; transform: translateY(-3px); box-shadow: 0 6px 18px rgba(100,70,10,0.15); }
    .ss-map-card img { width: 100%; height: 150px; object-fit: cover; display: block; }
    .ss-map-label {
      color: #2a1f0e; font-family: Georgia, serif; font-size: 11px;
      padding: 7px 8px; text-align: center; line-height: 1.35;
    }

    /* ── Label Panel — always visible in left sidebar ── */
    #label-panel {
      display: block;
      padding: 12px 10px;
    }

    .lp-title {
      color: #7a5c1e;
      font-size: 10px;
      letter-spacing: 1.5px;
      text-transform: uppercase;
      text-align: center;
      margin-bottom: 10px;
      border-bottom: 1px solid #d4b870;
      padding-bottom: 6px;
      font-family: Georgia, serif;
    }

    #lp-input {
      width: 100%;
      box-sizing: border-box;
      background: #faf5ea;
      border: 1.5px solid #c8a030;
      border-radius: 6px;
      color: #2a1f0e;
      font-family: Georgia, serif;
      font-size: 13px;
      padding: 6px 8px;
      margin-bottom: 10px;
      outline: none;
    }
    #lp-input:focus { border-color: #8a5808; }
    #lp-input::placeholder { color: #a08850; font-style: italic; }

    .lp-section-lbl {
      color: #7a5c1e;
      font-family: Georgia, serif;
      font-size: 9px;
      letter-spacing: 1px;
      text-transform: uppercase;
      margin-bottom: 5px;
    }

    .lp-color-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 5px;
      margin-bottom: 10px;
    }
    .lp-color-swatch {
      width: 24px; height: 24px;
      border-radius: 50%;
      border: 2px solid #c8a030;
      cursor: pointer;
      transition: border-color 0.12s, transform 0.1s;
      box-shadow: 0 1px 4px rgba(0,0,0,0.2);
    }
    .lp-color-swatch:hover  { border-color: #8a5808; transform: scale(1.15); }
    .lp-color-swatch.active { border-color: #2a1f0e; box-shadow: 0 0 0 2px #c8a030, 0 1px 4px rgba(0,0,0,0.2); }

    .lp-size-row {
      display: flex;
      align-items: center;
      gap: 4px;
      margin-bottom: 8px;
    }
    .lp-size-btn {
      background: #faf5ea;
      border: 1.5px solid #c8a030;
      border-radius: 5px;
      color: #2a1f0e;
      font-size: 14px;
      font-family: Georgia, serif;
      width: 26px; height: 26px;
      cursor: pointer;
      line-height: 1;
      flex-shrink: 0;
    }
    .lp-size-btn:hover { background: #e8d8a0; border-color: #8a5808; }
    #lp-size-display {
      flex: 1;
      text-align: center;
      color: #2a1f0e;
      font-size: 12px;
      font-family: Georgia, serif;
    }

    .lp-style-row {
      display: flex;
      gap: 4px;
      margin-bottom: 12px;
    }
    .lp-style-btn {
      flex: 1;
      padding: 4px 0;
      background: #faf5ea;
      border: 1.5px solid #c8a030;
      border-radius: 5px;
      color: #2a1f0e;
      font-size: 11px;
      font-family: Georgia, serif;
      cursor: pointer;
      text-align: center;
      transition: background 0.12s, border-color 0.12s;
    }
    .lp-style-btn:hover  { background: #e8d8a0; border-color: #8a5808; }
    .lp-style-btn.active { background: linear-gradient(180deg, #a06810 0%, #7a4c08 100%); border-color: #c8a030; color: #fff; }

    /* Draggable preview chip */
    #lp-preview-wrap {
      margin-bottom: 6px;
    }
    #lp-preview {
      background: #faf6ee;
      border: 2px dashed #c8a84b;
      border-radius: 7px;
      padding: 8px 6px;
      text-align: center;
      cursor: grab;
      min-height: 36px;
      display: flex;
      align-items: center;
      justify-content: center;
      transition: background 0.12s, border-color 0.12s;
      user-select: none;
    }
    #lp-preview:hover    { background: #fff; border-color: #e0c060; }
    #lp-preview:active   { cursor: grabbing; }
    #lp-preview.empty    { border-style: dashed; opacity: 0.4; cursor: default; }
    #lp-preview-text     { font-family: Georgia, serif; white-space: nowrap; max-width: 120px; overflow: hidden; text-overflow: ellipsis; }

    .lp-hint {
      color: #8a7050;
      font-family: Georgia, serif;
      font-size: 9px;
      text-align: center;
      font-style: italic;
    }

    /* Drag ghost */
    #lp-ghost {
      position: fixed;
      pointer-events: none;
      z-index: 9999;
      background: #faf6ee;
      border: 2px solid #c8a84b;
      border-radius: 6px;
      padding: 4px 10px;
      opacity: 0.88;
      display: none;
      font-family: Georgia, serif;
      white-space: nowrap;
      box-shadow: 0 4px 14px rgba(0,0,0,0.5);
      transform: translate(-50%, -50%);
    }

    /* ── On-map Key Overlay ── */
    #onmap-key {
      display: none;
      position: absolute;
      min-width: 150px;
      max-width: 460px;
      background: #faf6ee;
      border: 2px solid #222;
      border-radius: 3px;
      font-family: Georgia, serif;
      box-shadow: 3px 4px 14px rgba(0,0,0,0.45);
      pointer-events: auto;
      user-select: none;
      z-index: 50;
      left: 2%;
      top: 50%;
      transform: translateY(-50%);
      width: 200px;
    }
    #onmap-key.visible { display: block; }

    #onmap-key-header {
      background: #ede8d5;
      border-bottom: 1.5px solid #333;
      padding: 5px 8px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      cursor: grab;
      border-radius: 1px 1px 0 0;
    }
    #onmap-key-header:active { cursor: grabbing; }
    #onmap-key-htitle {
      font-size: 12px;
      font-weight: bold;
      color: #111;
      letter-spacing: 1.5px;
      text-transform: uppercase;
    }
    #onmap-key-collapse {
      background: none;
      border: 1px solid #888;
      border-radius: 2px;
      color: #333;
      font-size: 13px;
      width: 18px; height: 18px;
      cursor: pointer;
      line-height: 1;
      padding: 0;
      flex-shrink: 0;
      font-family: Georgia, serif;
    }
    #onmap-key-collapse:hover { background: #d5cdb8; }

    #onmap-key-body {
      padding: 0;
      overflow: hidden;
    }
    .ok-entry {
      display: flex;
      align-items: center;
      gap: 5px;
      padding: 1px 0;
    }
    .ok-entry canvas { flex-shrink: 0; display: block; }
    .ok-entry-label {
      font-family: Georgia, serif;
      font-size: 12px;
      color: #111;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }
    .ok-empty-hint {
      font-family: Georgia, serif;
      font-size: 10px;
      font-style: italic;
      color: #999;
      padding: 4px 2px;
    }

    #onmap-key-resize {
      position: absolute;
      right: 0; bottom: 0;
      width: 18px; height: 18px;
      cursor: se-resize;
      display: flex;
      align-items: flex-end;
      justify-content: flex-end;
      padding: 2px 3px;
      color: #888;
      font-size: 11px;
      line-height: 1;
      pointer-events: auto;
    }

    /* Key modal placement row */
    .km-placement {
      border-top: 1px solid #d4b870;
      margin-top: 10px;
      padding-top: 10px;
      display: flex;
      align-items: center;
      gap: 6px;
      flex-wrap: wrap;
    }
    .km-place-lbl {
      color: #7a5c1e;
      font-size: 11px;
      font-family: Georgia, serif;
      flex-shrink: 0;
    }
    .km-place-btn {
      padding: 4px 10px;
      background: #faf5ea;
      border: 1.5px solid #c8a030;
      border-radius: 5px;
      color: #2a1f0e;
      font-size: 11px;
      font-family: Georgia, serif;
      cursor: pointer;
      transition: background 0.12s, border-color 0.12s;
    }
    .km-place-btn:hover  { background: #e8d8a0; border-color: #8a5808; }
    .km-place-btn.active { background: linear-gradient(180deg, #a06810 0%, #7a4c08 100%); border-color: #c8a030; color: #fff; }

    /* Text overlay sits exactly over the canvas */
    #text-overlay {
      position: absolute;
      top: 0; left: 0;
      width: 100%; height: 100%;
      pointer-events: none;
      overflow: visible;
    }

    /* ── Text boxes ── */
    .text-box {
      position: absolute;
      pointer-events: auto;
      transform-origin: center center;
      user-select: none;
    }

    .tb-rotate-line {
      position: absolute;
      left: 50%;
      bottom: 100%;
      transform: translateX(-50%);
      width: 1px;
      height: 22px;
      background: #4a6fa5;
      display: none;
    }
    .tb-rotate-handle {
      position: absolute;
      left: 50%;
      bottom: calc(100% + 22px);
      transform: translateX(-50%);
      width: 14px; height: 14px;
      background: #fff;
      border: 2px solid #4a6fa5;
      border-radius: 50%;
      cursor: grab;
      display: none;
    }
    .tb-rotate-handle:active { cursor: grabbing; }

    .text-box.selected .tb-rotate-line,
    .text-box.selected .tb-rotate-handle { display: block; }

    .tb-content {
      font-family: Georgia, serif;
      white-space: nowrap;
      outline: none;
      padding: 2px 5px;
      min-width: 10px;
      border: 2px dashed transparent;
      cursor: move;
      line-height: 1.3;
    }
    .text-box.selected .tb-content {
      border-color: #4a6fa5;
      cursor: text;
    }
  </style>
</head>
<body>

<div id="toolbar">

  <!-- ── Row 1: Tools ── -->
  <div class="toolbar-row">
    <span class="lbl">Stamps:</span>

    <button class="stamp-btn active" id="btn-mountain" onclick="selectStamp('mountain')" title="Mountain">
      <canvas id="icon-mountain" width="28" height="22"></canvas>
    </button>
    <button class="stamp-btn" id="btn-peak" onclick="selectStamp('peak')" title="Major Peak">
      <canvas id="icon-peak" width="28" height="22"></canvas>
    </button>
    <button class="stamp-btn" id="btn-city" onclick="selectStamp('city')" title="City">
      <canvas id="icon-city" width="28" height="22"></canvas>
    </button>
    <button class="stamp-btn" id="btn-desert" onclick="selectStamp('desert')" title="Desert">
      <canvas id="icon-desert" width="28" height="22"></canvas>
    </button>
    <button class="stamp-btn" id="btn-oasis" onclick="selectStamp('oasis')" title="Oasis">
      <canvas id="icon-oasis" width="28" height="22"></canvas>
    </button>
    <button class="stamp-btn" id="btn-danger" onclick="selectStamp('danger')" title="Danger">
      <canvas id="icon-danger" width="28" height="22"></canvas>
    </button>
    <button class="stamp-btn" id="btn-battle" onclick="selectStamp('battle')" title="Battle">
      <canvas id="icon-battle" width="28" height="22"></canvas>
    </button>
    <button class="stamp-btn" id="btn-shade" onclick="selectStamp('shade')" title="Shade">
      <canvas id="icon-shade" width="28" height="22"></canvas>
    </button>
    <button class="stamp-btn" id="btn-fill" onclick="selectStamp('fill')" title="Fill" style="display:none">
      <span style="font-size:17px;line-height:1;display:block;">🪣</span>
    </button>
    <button class="stamp-btn" id="btn-arrow-black" onclick="selectStamp('arrow-black')" title="Arrow">
      <canvas id="icon-arrow-black" width="28" height="22"></canvas>
    </button>
    <button class="stamp-btn" id="btn-eraser" onclick="selectStamp('eraser')" title="Eraser">
      <span style="font-size:15px;line-height:1;display:block;">⌫</span>
    </button>

    <span class="sep">|</span>
    <span class="lbl">Lines:</span>

    <button class="stamp-btn" id="btn-line-solid" onclick="selectStamp('line-solid')" title="Solid Line">
      <canvas id="icon-line-solid" width="36" height="22"></canvas>
    </button>
    <button class="stamp-btn" id="btn-line-dotted" onclick="selectStamp('line-dotted')" title="Dotted Line">
      <canvas id="icon-line-dotted" width="36" height="22"></canvas>
    </button>
    <button class="stamp-btn" id="btn-line-dashed" onclick="selectStamp('line-dashed')" title="Dashed Line">
      <canvas id="icon-line-dashed" width="36" height="22"></canvas>
    </button>
    <button class="stamp-btn" id="btn-line-dashdot" onclick="selectStamp('line-dashdot')" title="Dash-Dot Line">
      <canvas id="icon-line-dashdot" width="36" height="22"></canvas>
    </button>

    <button class="stamp-btn" onclick="undo()" title="Undo" style="color:#ff9999;border-color:#884444;">↩</button>
    <button class="stamp-btn" id="btn-redo" onclick="redo()" title="Redo" style="color:#e8d060;border-color:#8a7020;">↪</button>
    <span class="sep">|</span>
    <button class="stamp-btn" onclick="openKeyModal()" title="Map Key" style="color:#d8c878;border-color:#8a7840;">🗝</button>
    <button class="stamp-btn" onclick="openTitleModal()" title="Map Title" style="color:#e0c870;border-color:#907828;">🏷</button>
    <button class="stamp-btn" onclick="exportMap()" title="Export PNG" style="color:#d4b860;border-color:#886830;">⬇</button>
    <span class="sep">|</span>
    <button class="stamp-btn" onclick="navChangeMap()" title="Change Map" style="color:#ffcc88;border-color:#886633;">🗺</button>
    <button class="stamp-btn" onclick="navHome()" title="Home" style="color:#ffaaaa;border-color:#884444;">🏠</button>
  </div>

  <!-- ── Row 2: Context-sensitive controls ── -->
  <div class="toolbar-row" id="row2">

    <!-- Color — shown for every tool except Eraser -->
    <div id="color-ctrl" style="display:flex;align-items:center;gap:6px;flex-shrink:0;">
      <span class="lbl">Color:</span>
      <button class="color-btn active" onclick="setActiveColor('#111111')" style="background:#111111;" title="Black"></button>
      <button class="color-btn"        onclick="setActiveColor('#888888')" style="background:#888888;" title="Gray"></button>
      <button class="color-btn"        onclick="setActiveColor('#ffffff')" style="background:#ffffff;border-color:#999;" title="White"></button>
      <button class="color-btn"        onclick="setActiveColor('#cc2200')" style="background:#cc2200;" title="Red"></button>
      <button class="color-btn"        onclick="setActiveColor('#2a7a2a')" style="background:#2a7a2a;" title="Green"></button>
      <button class="color-btn"        onclick="setActiveColor('#1a4d99')" style="background:#1a4d99;" title="Blue"></button>
      <button class="color-btn"        onclick="setActiveColor('#6b3a1f')" style="background:#6b3a1f;" title="Brown"></button>
      <button class="color-btn"        onclick="setActiveColor('#b8860b')" style="background:#b8860b;" title="Dark Yellow"></button>
      <button class="color-btn"        onclick="setActiveColor('#6a0dad')" style="background:#6a0dad;" title="Purple"></button>
    </div>

    <!-- Shade controls — shown only for Shade tool -->
    <div id="shade-ctrl" style="display:none;align-items:center;gap:6px;flex-shrink:0;">
      <span class="sep">|</span>
      <span class="lbl">Brush&nbsp;size:</span>
      <input type="range" id="shade-size-slider" min="15" max="220" value="60" step="5"
             oninput="shadeSize=+this.value; updateShadeCursor(lastShadeMouseE)">
      <span id="shade-size-display" style="color:#ccc;font-size:11px;min-width:28px;">60</span>
      <span class="sep">|</span>
      <span class="lbl" style="white-space:nowrap;">Fill:</span>
      <button class="shade-style-btn active" id="ssbtn-solid"  onclick="setShadeStyle('solid')">Solid</button>
      <button class="shade-style-btn"        id="ssbtn-stripe" onclick="setShadeStyle('stripe')" title="Diagonal stripes">Pattern</button>
      <button class="shade-style-btn"        id="ssbtn-plus"   onclick="setShadeStyle('plus')"   title="Plus marks">Plus</button>
    </div>

    <!-- Stamp size — shown for Mountain / Peak / City -->
    <div id="stamp-size-ctrl" style="display:none;align-items:center;gap:6px;flex-shrink:0;">
      <span class="sep">|</span>
      <span class="lbl">Stamp&nbsp;size:</span>
      <input type="range" id="stamp-size-slider" min="8" max="80" value="22" step="2"
             oninput="stampSize=+this.value; if(activeStamp==='city') citySize=stampSize; else mountainSize=stampSize; document.getElementById('stamp-size-display').textContent=stampSize">
      <span id="stamp-size-display" style="color:#ccc;font-size:11px;min-width:28px;">22</span>
