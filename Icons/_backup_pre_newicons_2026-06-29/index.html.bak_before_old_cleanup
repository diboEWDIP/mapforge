function drawWheat_OLD(ctx, x, y, size) {
  ctx.save();
  ctx.strokeStyle = '#111'; ctx.lineCap = 'round'; ctx.lineJoin = 'round';
  const bindY = y + size * 0.18;
  [[-30, 0.82], [-15, 0.92], [0, 1.0], [15, 0.92], [30, 0.82]].forEach(([deg, fac]) => {
    const rad = deg * Math.PI / 180;
    const len = size * 0.72 * fac;
    const ex  = x + Math.sin(rad) * len, ey = bindY - Math.cos(rad) * len;
    ctx.lineWidth = 1.4;
    ctx.beginPath(); ctx.moveTo(x + Math.sin(rad) * size * 0.07, bindY); ctx.lineTo(ex, ey); ctx.stroke();
    ctx.lineWidth = 1.2;
    const hLen = size * 0.19, hW = size * 0.07;
    ctx.beginPath(); ctx.ellipse(ex, ey - hLen * 0.3, hW, hLen * 0.65, rad, 0, Math.PI * 2); ctx.stroke();
    ctx.lineWidth = 0.8;
    [-0.15, 0.15].forEach(t => {
      const hx = ex + Math.cos(rad) * hLen * t, hy = ey - hLen * 0.3 - Math.sin(rad) * hLen * t;
      ctx.beginPath();
      ctx.moveTo(hx - Math.cos(rad) * hW, hy - Math.sin(rad) * hW);
      ctx.lineTo(hx + Math.cos(rad) * hW, hy + Math.sin(rad) * hW);
      ctx.stroke();
    });
  });
  ctx.lineWidth = 2.5;
  ctx.beginPath(); ctx.moveTo(x - size * 0.18, bindY); ctx.lineTo(x + size * 0.18, bindY); ctx.stroke();
  ctx.lineWidth = 1.4;
  [[-16, 0.38], [0, 0.42], [16, 0.38]].forEach(([deg, len]) => {
    const rad = deg * Math.PI / 180;
    ctx.beginPath();
    ctx.moveTo(x + Math.sin(rad) * size * 0.06, bindY);
    ctx.lineTo(x + Math.sin(rad) * size * len, bindY + Math.cos(rad) * size * len);
    ctx.stroke();
  });
  ctx.restore();
}

