function drawHorse_OLD(ctx, x, y, size) {
  // Horseshoe — thick U-shape, open at bottom, nail holes on both arms
  // Canvas angle convention: 0=right, 90=screen-DOWN, 180=left, 270=screen-UP
  // anticlockwise=false (clockwise) goes the long way from startA → UP → endA → U shape ✓
  ctx.save();

  const r  = size * 0.40;     // radius to stroke center
  const sw = size * 0.21;     // shoe thickness
  const cy = y - size * 0.04; // arc center — slight upward offset

  // Prong tips at 130° and 50° (lower-left and lower-right, pointing down and outward)
  // Clockwise from 130° → 180° → 270°(top) → 0° → 50° traces the U over the top ✓
  const startA = 130 * Math.PI / 180;
  const endA   =  50 * Math.PI / 180;

  ctx.strokeStyle = '#111';
  ctx.lineWidth   = sw;
  ctx.lineCap     = 'butt';   // flat-cut prong ends (like a real shoe)
  ctx.beginPath();
  ctx.arc(x, cy, r, startA, endA, false); // false = clockwise = over the top
  ctx.stroke();

  // Nail holes — 3 per arm, white dots spaced along each arm section
  // Left arm angles (130°→100°), right arm angles (80°→50°) — all in lower quadrants
  ctx.fillStyle = '#fff';
  const holeR = size * 0.07;
  [127, 112, 97,   83, 68, 53].forEach(deg => {
    const a = deg * Math.PI / 180;
    ctx.beginPath();
    ctx.arc(x + r * Math.cos(a), cy + r * Math.sin(a), holeR, 0, Math.PI * 2);
    ctx.fill();
  });

  ctx.restore();
}

function drawAmphora_OLD(ctx, x, y, size) {
  // Amphora — tall clay vessel with two handles and pointed base
  ctx.save();
  ctx.strokeStyle = '#111'; ctx.lineWidth = 1.3; ctx.lineJoin = 'round'; ctx.lineCap = 'round';

  const nW  = size * 0.16;   // neck half-width
  const shW = size * 0.42;   // shoulder/belly half-width
  const lipW = size * 0.20;  // lip half-width
  const top = y - size * 0.52;
  const sh  = y - size * 0.22;  // shoulder level
  const mid = y + size * 0.10;  // belly widest
  const bot = y + size * 0.52;  // bottom point

  // Body outline
  ctx.fillStyle = '#e8d8b0';
  ctx.beginPath();
  ctx.moveTo(x - lipW, top);
  ctx.lineTo(x - nW,   top + size*0.08);
  ctx.lineTo(x - nW,   sh);
  ctx.bezierCurveTo(x - shW, sh + size*0.12, x - shW*0.5, mid, x,       bot);
  ctx.bezierCurveTo(x + shW*0.5, mid, x + shW, sh + size*0.12, x + nW,  sh);
  ctx.lineTo(x + nW,   top + size*0.08);
  ctx.lineTo(x + lipW, top);
  ctx.closePath();
  ctx.fill(); ctx.stroke();

  // Left handle
  ctx.fillStyle = 'none';
  ctx.beginPath(); ctx.arc(x - shW*0.80, sh + size*0.06, size*0.17, -Math.PI*0.5, Math.PI*0.55); ctx.stroke();
  // Right handle
  ctx.beginPath(); ctx.arc(x + shW*0.80, sh + size*0.06, size*0.17, Math.PI - Math.PI*0.55, Math.PI + Math.PI*0.5); ctx.stroke();

  // Neck ring
  ctx.lineWidth = 1.0;
  ctx.beginPath(); ctx.moveTo(x - nW - 1, sh); ctx.lineTo(x + nW + 1, sh); ctx.stroke();

  // Body decorative band
  ctx.beginPath(); ctx.moveTo(x - shW*0.72, mid - size*0.04); ctx.lineTo(x + shW*0.72, mid - size*0.04); ctx.stroke();

  ctx.restore();
}

