}

function drawDanger(ctx, x, y, size) {
  // Skull and crossbones
  ctx.save();
  ctx.fillStyle = '#111'; ctx.strokeStyle = '#111';

  const sy = y - size * 0.06;  // skull center, shifted slightly up to leave room for crossbones
  const r  = size * 0.28;

  // Crossbones — drawn BEHIND skull
  ctx.lineWidth = size * 0.13; ctx.lineCap = 'round';
  ctx.beginPath(); ctx.moveTo(x - size*0.52, sy + size*0.48); ctx.lineTo(x + size*0.52, sy - size*0.36); ctx.stroke();
  ctx.beginPath(); ctx.moveTo(x + size*0.52, sy + size*0.48); ctx.lineTo(x - size*0.52, sy - size*0.36); ctx.stroke();
  // Bone knobs at ends
  [[x - size*0.52, sy + size*0.48],[x + size*0.52, sy - size*0.36],
   [x + size*0.52, sy + size*0.48],[x - size*0.52, sy - size*0.36]].forEach(([bx, by]) => {
    ctx.beginPath(); ctx.arc(bx, by, size*0.095, 0, Math.PI*2); ctx.fill();
  });

  // Skull dome
  ctx.fillStyle = '#111';
  ctx.beginPath(); ctx.arc(x, sy, r, 0, Math.PI*2); ctx.fill();

  // Jaw — rounded rectangle below skull
  ctx.beginPath();
  ctx.moveTo(x - r*0.70, sy + r*0.55);
  ctx.bezierCurveTo(x - r*0.70, sy + r*1.20, x + r*0.70, sy + r*1.20, x + r*0.70, sy + r*0.55);
  ctx.fill();

  // Eye sockets — white ovals
  ctx.fillStyle = '#fff';
  ctx.beginPath(); ctx.ellipse(x - r*0.36, sy - r*0.08, r*0.20, r*0.23, 0, 0, Math.PI*2); ctx.fill();
  ctx.beginPath(); ctx.ellipse(x + r*0.36, sy - r*0.08, r*0.20, r*0.23, 0, 0, Math.PI*2); ctx.fill();

  // Nose hole — small inverted triangle
  ctx.beginPath();
  ctx.moveTo(x,          sy + r*0.22);
  ctx.lineTo(x - r*0.13, sy + r*0.50);
  ctx.lineTo(x + r*0.13, sy + r*0.50);
  ctx.closePath(); ctx.fill();

  // Teeth — 3 white rectangles at jaw bottom
  [-r*0.36, 0, r*0.36].forEach(dx => {
    ctx.beginPath();
    ctx.rect(x + dx - r*0.10, sy + r*0.70, r*0.20, r*0.30);
    ctx.fill();
  });

  ctx.restore();
}

function drawBattle(ctx, x, y, size) {
  // Two crossed swords — blades cross at center, guards near lower corners
  ctx.save();
  ctx.strokeStyle = '#111';
  ctx.fillStyle = '#111';
  ctx.lineCap = 'round';

  const halfX = size * 0.50;
  const halfY = size * 0.50;
  const sw    = size * 0.10;  // blade width

  const GUARD_T = 0.22;       // guard at 22% from pommel — well into lower corners
  const GRIP_T  = 0.28;       // grip ends here, blade begins

  [1, -1].forEach(dir => {
    const x1 = x - dir * halfX,  y1 = y + halfY;  // pommel end (bottom corner)
    const x2 = x + dir * halfX,  y2 = y - halfY;  // tip (top corner)

    const dx = x2 - x1, dy = y2 - y1;
    const len = Math.hypot(dx, dy);
    const ux = dx / len, uy = dy / len;
    const nx = -uy, ny = ux;

    // Blade (thin, tapered): from grip end to tip — single line, rounded cap
    ctx.lineWidth = sw;
    ctx.beginPath();
    ctx.moveTo(x1 + ux * len * GRIP_T, y1 + uy * len * GRIP_T);
    ctx.lineTo(x2, y2);
    ctx.stroke();

    // Grip: smooth, slightly thicker — no pommel ball, just a rounded end
    ctx.lineWidth = sw * 1.35;
    ctx.lineCap = 'round';
    ctx.beginPath();
    ctx.moveTo(x1, y1);
    ctx.lineTo(x1 + ux * len * GRIP_T, y1 + uy * len * GRIP_T);
    ctx.stroke();

    // Guard — crosspiece perpendicular to blade
    const gx = x1 + ux * len * GUARD_T;
    const gy = y1 + uy * len * GUARD_T;
    ctx.lineWidth = sw * 1.15;
    ctx.lineCap = 'round';
    ctx.beginPath();
    ctx.moveTo(gx - nx * size * 0.32, gy - ny * size * 0.32);
    ctx.lineTo(gx + nx * size * 0.32, gy + ny * size * 0.32);
    ctx.stroke();
  });

  ctx.restore();
}

function drawTin_OLD(ctx, x, y, size) {
  // Tin ingot — trapezoidal bar, light metallic grey
  ctx.save();
  const bw = size * 0.78, bh = size * 0.40, slant = size * 0.12;
  ctx.strokeStyle = '#444'; ctx.lineWidth = 1.2; ctx.lineJoin = 'round';

  // Top bevel face (lighter)
  ctx.fillStyle = '#ccc';
  ctx.beginPath();
  ctx.moveTo(x - bw/2 + slant, y - bh/2 - slant*0.5);
  ctx.lineTo(x + bw/2 - slant, y - bh/2 - slant*0.5);
  ctx.lineTo(x + bw/2,         y - bh/2);
  ctx.lineTo(x - bw/2,         y - bh/2);
  ctx.closePath(); ctx.fill(); ctx.stroke();

  // Right side face (darker)
  ctx.fillStyle = '#888';
  ctx.beginPath();
  ctx.moveTo(x + bw/2 - slant, y - bh/2 - slant*0.5);
  ctx.lineTo(x + bw/2 - slant, y + bh/2 - slant*0.5);
  ctx.lineTo(x + bw/2,         y + bh/2);
  ctx.lineTo(x + bw/2,         y - bh/2);
  ctx.closePath(); ctx.fill(); ctx.stroke();

  // Front face (mid-grey)
  ctx.fillStyle = '#aaa';
  ctx.beginPath();
  ctx.rect(x - bw/2, y - bh/2, bw, bh);
  ctx.fill(); ctx.stroke();

  // Sheen highlight on front
  ctx.strokeStyle = '#ddd'; ctx.lineWidth = 0.8; ctx.lineCap = 'round';
  ctx.beginPath(); ctx.moveTo(x - bw/2 + 3, y - bh/2 + 3); ctx.lineTo(x + bw/2 - 3, y - bh/2 + 3); ctx.stroke();

  // Label "Sn" — tin's chemical symbol
  ctx.fillStyle = '#555'; ctx.font = `bold ${Math.round(size*0.30)}px Georgia,serif`;
  ctx.textAlign = 'center'; ctx.textBaseline = 'middle';
  ctx.fillText('Sn', x, y + size*0.02);
  ctx.restore();
}

function drawCopper_OLD(ctx, x, y, size) {
  // Copper disc stack — stacked round ingots/coins, reddish
  ctx.save();
  ctx.strokeStyle = '#5a2800'; ctx.lineWidth = 1.2; ctx.lineJoin = 'round';
  const r = size * 0.40, diskH = size * 0.16;

  // Draw 3 discs bottom to top
  [size*0.20, size*0.05, -size*0.10].forEach((oy, i) => {
    const shade = i === 2 ? '#c06010' : (i === 1 ? '#a04e0e' : '#7a3a0a');
    ctx.fillStyle = shade;
    // Ellipse face
    ctx.beginPath(); ctx.ellipse(x, y + oy - diskH/2, r, diskH*0.45, 0, 0, Math.PI*2); ctx.fill(); ctx.stroke();
    // Side band
    if (i < 2) {
      ctx.fillStyle = shade;
      ctx.beginPath();
      ctx.moveTo(x - r, y + oy - diskH/2);
      ctx.lineTo(x - r, y + oy + diskH/2);
      ctx.bezierCurveTo(x - r, y + oy + diskH/2 + diskH*0.45,
                        x + r, y + oy + diskH/2 + diskH*0.45,
                        x + r, y + oy + diskH/2);
      ctx.lineTo(x + r, y + oy - diskH/2);
      ctx.fill();
      ctx.beginPath(); ctx.moveTo(x - r, y + oy + diskH/2); ctx.bezierCurveTo(x - r, y + oy + diskH/2 + diskH*0.45, x + r, y + oy + diskH/2 + diskH*0.45, x + r, y + oy + diskH/2); ctx.stroke();
      ctx.beginPath(); ctx.moveTo(x - r, y + oy - diskH/2); ctx.lineTo(x - r, y + oy + diskH/2); ctx.stroke();
      ctx.beginPath(); ctx.moveTo(x + r, y + oy - diskH/2); ctx.lineTo(x + r, y + oy + diskH/2); ctx.stroke();
    }
  });
  ctx.restore();
}

function drawPaper_OLD(ctx, x, y, size) {
  // Sheet of paper with folded corner and lines
  ctx.save();
  const pw = size * 0.72, ph = size * 0.85, fold = size * 0.20;
  ctx.strokeStyle = '#333'; ctx.lineWidth = 1.2; ctx.lineJoin = 'round';

  // Paper body
  ctx.fillStyle = '#f8f6ee';
  ctx.beginPath();
  ctx.moveTo(x - pw/2, y - ph/2);
  ctx.lineTo(x + pw/2 - fold, y - ph/2);
  ctx.lineTo(x + pw/2, y - ph/2 + fold);
  ctx.lineTo(x + pw/2, y + ph/2);
  ctx.lineTo(x - pw/2, y + ph/2);
  ctx.closePath(); ctx.fill(); ctx.stroke();

  // Folded corner triangle
  ctx.fillStyle = '#ddd8c8';
  ctx.beginPath();
  ctx.moveTo(x + pw/2 - fold, y - ph/2);
  ctx.lineTo(x + pw/2, y - ph/2 + fold);
  ctx.lineTo(x + pw/2 - fold, y - ph/2 + fold);
  ctx.closePath(); ctx.fill(); ctx.stroke();

  // Writing lines
  ctx.strokeStyle = '#999'; ctx.lineWidth = 0.7; ctx.lineCap = 'round';
  [-0.22, 0, 0.22].forEach(t => {
    ctx.beginPath();
    ctx.moveTo(x - pw/2 + size*0.08, y + t * ph * 0.52);
    ctx.lineTo(x + pw/2 - size*0.12, y + t * ph * 0.52);
    ctx.stroke();
  });
  ctx.restore();
}

// ── Image-stamp factory (flood-fill background removal) ──────────────────────
function _removeBackground(data, width, height, tolerance) {
  // Sample background color from the four corners and average them
  const corners = [0, (width-1), (height-1)*width, (height-1)*width+(width-1)];
  let bgR=0, bgG=0, bgB=0;
  corners.forEach(p => { bgR+=data[p*4]; bgG+=data[p*4+1]; bgB+=data[p*4+2]; });
  bgR=Math.round(bgR/4); bgG=Math.round(bgG/4); bgB=Math.round(bgB/4);

  // BFS flood-fill from all four corners, removing pixels close to bg color
  const visited = new Uint8Array(width * height);
  const queue = [...corners];
  let head = 0;
  while (head < queue.length) {
    const pos = queue[head++];
    if (visited[pos]) continue;
    visited[pos] = 1;
    const i = pos * 4;
    const dr = data[i]-bgR, dg = data[i+1]-bgG, db = data[i+2]-bgB;
    if (Math.sqrt(dr*dr + dg*dg + db*db) <= tolerance) {
      data[i+3] = 0;
      const x = pos % width, y = Math.floor(pos / width);
      if (x > 0)        queue.push(pos - 1);
      if (x < width-1)  queue.push(pos + 1);
      if (y > 0)        queue.push(pos - width);
      if (y < height-1) queue.push(pos + width);
    }
  }

  // Boost remaining (non-background) pixels to pure black with stronger opacity
  for (let i = 0; i < data.length; i += 4) {
    if (data[i+3] > 0) {
      const lum = 0.299*data[i] + 0.587*data[i+1] + 0.114*data[i+2];
      data[i+3] = Math.min(255, Math.round((255 - lum) * 1.5));
      data[i] = 0; data[i+1] = 0; data[i+2] = 0;
    }
  }
}

function _makeImageStamp(src, toolbarId, tolerance=40) {
  let _canvas = null;
  const img = new Image();
  img.onload = () => {
    const oc = document.createElement('canvas');
    oc.width = img.naturalWidth; oc.height = img.naturalHeight;
    const oc2 = oc.getContext('2d');
    oc2.drawImage(img, 0, 0);
    const id = oc2.getImageData(0, 0, oc.width, oc.height);
    _removeBackground(id.data, oc.width, oc.height, tolerance);
    oc2.putImageData(id, 0, 0);
    _canvas = oc;
    if (toolbarId) {
      const c = document.getElementById(toolbarId);
      if (c) draw(c.getContext('2d'), c.width/2, c.height/2, c.width*0.44);
    }
  };
  img.src = src;
  function draw(ctx, x, y, size) {
    const w = size * 1.6, h = size * 1.25;
    ctx.save();
    if (_canvas) ctx.drawImage(_canvas, x - w/2, y - h/2, w, h);
    ctx.restore();
  }
  return draw;
}

