// ── Key icon drawing ─────────────────────────────────────────────────────────

function drawKeyEntryIcon(ec, entry, cx, cy) {
  const S  = KEY_ICON_SIZE;
  const hw = KEY_ICON_BOX_W * 0.42;  // half-width for horizontal line/feature icons

  switch (entry.kind) {
    case 'stamp-mountain':
      drawMountainIcon(ec, cx, cy, S, '#111');
      break;
    case 'stamp-city':
      drawCityIcon(ec, cx, cy, S * 0.7, '#111');
      break;
    case 'stamp-desert':
      drawDesertIcon(ec, cx, cy, S / 44, '#111');
      break;
    case 'stamp-peak':
      drawPeakIcon(ec, cx, cy, S * 1.3, '#111');
      break;
    case 'stamp-oasis':
      drawOasis(ec, cx, cy, S * 1.1);
      break;
    case 'stamp-danger':
      drawDanger(ec, cx, cy, S * 1.1);
      break;
    case 'stamp-battle':
      drawBattle(ec, cx, cy, S * 1.1);
      break;
    case 'trade':
      entry.drawFn(ec, cx, cy, S);
      break;
    case 'religion':
      entry.drawFn(ec, cx, cy, S);
      break;
    case 'feature': {
      const pts = [
        {x: cx - hw,   y: cy},
        {x: cx - hw/2, y: cy},
        {x: cx,        y: cy},
        {x: cx + hw/2, y: cy},
        {x: cx + hw,   y: cy},
      ];
      drawFeatureLine(ec, pts, entry.featureType, '#111');
      break;
    }
    case 'line': {
      const pts = [{x: cx - hw, y: cy}, {x: cx, y: cy}, {x: cx + hw, y: cy}];
      drawStroke(ec, pts, entry.lineStyle, entry.color);
      break;
    }
    case 'shade': {
      // Draw shade as a filled rectangle (clear, recognizable in the key)
      const rw = Math.round(KEY_ICON_BOX_W * 0.82);
      const rh = Math.round(KEY_ROW_H     * 0.44);
      const rx = cx - rw / 2;
      const ry = cy - rh / 2;
      // Tile size for patterns must be large enough; fill an oversized tmp then clip
      const dim  = Math.max(rw, rh) * 4;
      const tmpC = document.createElement('canvas');
      tmpC.width = tmpC.height = dim;
      const tc   = tmpC.getContext('2d');
      if (entry.shadeStyle === 'solid') {
        tc.fillStyle = entry.color;
        tc.fillRect(0, 0, dim, dim);
      } else if (entry.shadeStyle === 'stripe') {
        tc.fillStyle = makeStripePattern(tc, entry.color);
        tc.fillRect(0, 0, dim, dim);
      } else if (entry.shadeStyle === 'plus') {
        tc.fillStyle = lightenColor(entry.color, 0.52);
        tc.fillRect(0, 0, dim, dim);
        tc.strokeStyle = entry.color; tc.lineWidth = 1.5; tc.lineCap = 'round';
        const sp = 14;
        for (let dx = sp/2; dx < dim; dx += sp)
          for (let dy = sp/2; dy < dim; dy += sp)
            drawPlus(tc, dx, dy, 5);
      }
      ec.save();
      ec.beginPath(); ec.rect(rx, ry, rw, rh); ec.clip();
      ec.globalAlpha = SHADE_OPACITY;
      ec.drawImage(tmpC, rx, ry, dim, dim);
      ec.restore();
      ec.strokeStyle = '#111'; ec.lineWidth = 2;
      ec.strokeRect(rx, ry, rw, rh);
      break;
    }
    case 'arrow': {
      // Simple horizontal line → arrowhead pointing right
      const col   = entry.color || '#111';
      const lw    = Math.max(1.5, KEY_ICON_SIZE * 0.09);
      const x1    = cx - hw * 0.80;
      const x2    = cx + hw * 0.80;
      const hs    = KEY_ICON_SIZE * 0.30;   // arrowhead half-size
      ec.save();
      ec.strokeStyle = col; ec.fillStyle = col;
      ec.lineWidth   = lw;
      ec.lineCap     = 'round';
      // Shaft (stop short of arrowhead base)
      ec.beginPath();
      ec.moveTo(x1, cy);
      ec.lineTo(x2 - hs * 0.7, cy);
      ec.stroke();
      // Arrowhead triangle
      ec.beginPath();
      ec.moveTo(x2,         cy);
      ec.lineTo(x2 - hs,    cy - hs * 0.6);
      ec.lineTo(x2 - hs,    cy + hs * 0.6);
      ec.closePath();
      ec.fill();
      ec.restore();
      break;
    }
  }
}

// ── Auto-detect key entries from placed stamps ───────────────────────────────

function collectAutoKeyEntries() {
  const seen    = new Set();
  const entries = [];

  stamps.forEach(s => {
    if (seen.has(s.type) || keySuppressedTypes.has(s.type)) return;

    if (s.type === 'mountain') {
      seen.add('mountain');
      entries.push({ id:'mountain', label:'Mountain', kind:'stamp-mountain' });
    } else if (s.type === 'peak') {
      seen.add('peak');
      entries.push({ id:'peak', label:'Major Peak', kind:'stamp-peak' });
    } else if (s.type === 'city') {
      seen.add('city');
      entries.push({ id:'city', label:'City', kind:'stamp-city' });
    } else if (s.type === 'desert') {
      seen.add('desert');
      entries.push({ id:'desert', label:'Desert', kind:'stamp-desert' });
    } else if (s.type === 'oasis') {
      seen.add('oasis');
      entries.push({ id:'oasis', label:'Oasis', kind:'stamp-oasis' });
    } else if (s.type === 'danger') {
      seen.add('danger');
      entries.push({ id:'danger', label:'Danger', kind:'stamp-danger' });
    } else if (s.type === 'battle') {
      seen.add('battle');
      entries.push({ id:'battle', label:'Battle', kind:'stamp-battle' });
    } else if (isTradeStamp(s.type)) {
      seen.add(s.type);
      entries.push({ id:s.type, label:TRADE_GOODS[s.type].label, kind:'trade', drawFn:TRADE_GOODS[s.type].draw });
    } else if (isReligionStamp(s.type)) {
      seen.add(s.type);
      entries.push({ id:s.type, label:RELIGIONS[s.type].label, kind:'religion', drawFn:RELIGIONS[s.type].draw });
    } else if (s.type === 'feature-wall') {
      seen.add('feature-wall');
      entries.push({ id:'feature-wall', label:'Wall', kind:'feature', featureType:'feature-wall' });
    } else if (s.type === 'feature-railroad') {
      seen.add('feature-railroad');
      entries.push({ id:'feature-railroad', label:'Railroad', kind:'feature', featureType:'feature-railroad' });
    } else if (s.type === 'feature-canal') {
      seen.add('feature-canal');
      entries.push({ id:'feature-canal', label:'Canal', kind:'feature', featureType:'feature-canal' });
    }
  });

  // Apply any user-defined custom labels
  entries.forEach(e => { if (keyCustomLabels[e.id]) e.label = keyCustomLabels[e.id]; });
  // Apply custom labels to manual entries too (stored by id)
  keyManualEntries.forEach(e => { if (keyCustomLabels[e.id]) e.label = keyCustomLabels[e.id]; });

  return entries;
}

// ── Key box renderer (used by exportMap) ─────────────────────────────────────

function renderKeyBox(ec, mapW, mapH, entries) {
  const numCols = Math.ceil(entries.length / KEY_MAX_ROWS);
  const numRows = Math.min(entries.length, KEY_MAX_ROWS);

  // Measure each label so the box is exactly wide enough
  ec.font = `${KEY_FONT_SIZE}px Georgia, serif`;
  const maxLabelW = entries.reduce((m, e) => Math.max(m, ec.measureText(e.label).width), 0);
  const colW = KEY_ICON_BOX_W + KEY_ICON_LABEL_GAP + Math.ceil(maxLabelW) + KEY_COL_MARGIN;

  // Box is content-sized and left-aligned
  const boxW = KEY_PAD + numCols * colW + KEY_PAD;
  const boxH = KEY_PAD + KEY_TITLE_H + numRows * KEY_ROW_H + KEY_PAD;

  // Background (only under the box, not full map width)
  ec.fillStyle = '#faf6ee';
  ec.fillRect(0, mapH, boxW, boxH);

  // Border (inset by half line-width so all 4 sides are fully visible)
  const KBW = 3;
  ec.strokeStyle = '#111'; ec.lineWidth = KBW;
  ec.strokeRect(KBW / 2, mapH + KBW / 2, boxW - KBW, boxH - KBW);

  // Title centered within the box
  ec.fillStyle    = '#111';
  ec.font         = `bold ${KEY_FONT_SIZE + 4}px Georgia, serif`;
  ec.textAlign    = 'center';
  ec.textBaseline = 'middle';
  ec.fillText('MAP KEY', boxW / 2, mapH + KEY_PAD + KEY_TITLE_H / 2);

  // Divider under title
  ec.beginPath();
  ec.moveTo(KEY_PAD, mapH + KEY_PAD + KEY_TITLE_H);
  ec.lineTo(boxW - KEY_PAD, mapH + KEY_PAD + KEY_TITLE_H);
  ec.lineWidth = 1.5; ec.stroke();

  const colsStartX  = KEY_PAD;
  const itemsStartY = mapH + KEY_PAD + KEY_TITLE_H + 8;

  entries.forEach((entry, i) => {
    const col    = Math.floor(i / KEY_MAX_ROWS);
    const row    = i % KEY_MAX_ROWS;
    const itemX  = colsStartX + col * colW;
    const itemCY = itemsStartY + row * KEY_ROW_H + KEY_ROW_H / 2;

    // Icon centered in icon box
    drawKeyEntryIcon(ec, entry, itemX + KEY_ICON_BOX_W / 2, itemCY);

    // Label with gap after icon box
    ec.fillStyle    = '#111';
    ec.font         = `${KEY_FONT_SIZE}px Georgia, serif`;
    ec.textAlign    = 'left';
    ec.textBaseline = 'middle';
    ec.fillText(entry.label, itemX + KEY_ICON_BOX_W + KEY_ICON_LABEL_GAP, itemCY);
  });
}

// ── Export ────────────────────────────────────────────────────────────────────

function exportMap() {
  const mapW = canvas.width;
  const mapH = canvas.height;

  const autoEntries = collectAutoKeyEntries();
  const allEntries  = [...autoEntries, ...keyManualEntries];

  const MAP_BORDER = 3;
  const INSET      = 8;   // cream mat + edge ocean crop

  const numRows = Math.min(allEntries.length, KEY_MAX_ROWS);
  const keyBelow = allEntries.length > 0 && keyPlacement === 'below';
  const keyH     = keyBelow ? KEY_PAD + KEY_TITLE_H + numRows * KEY_ROW_H + KEY_PAD : 0;

  const exportCanvas  = document.createElement('canvas');
  exportCanvas.width  = mapW;
  exportCanvas.height = mapH + keyH;
  const ec = exportCanvas.getContext('2d');

  // Cream background (shows as mat inside border, and fills key area)
  ec.fillStyle = '#faf6ee';
  ec.fillRect(0, 0, exportCanvas.width, exportCanvas.height);

  // Map image inset — crops outer ocean pixels, reveals cream mat inside border
  ec.drawImage(
    canvas,
    INSET, INSET, canvas.width - INSET * 2, canvas.height - INSET * 2,
    INSET, INSET, mapW - INSET * 2, mapH - INSET * 2
  );

  // Solid black border — pixel-perfect fillRect, no antialiasing
  const B = MAP_BORDER;
  ec.fillStyle = '#111';
  ec.fillRect(0,        0,        mapW, B);   // top
  ec.fillRect(0,        mapH - B, mapW, B);   // bottom
  ec.fillRect(0,        0,        B,    mapH); // left
  ec.fillRect(mapW - B, 0,        B,    mapH); // right

  // Flatten text boxes (percentage coords remapped into inset map area)
  textBoxes.forEach(tb => {
    const text = tb.el.querySelector('.tb-content').textContent;
    if (!text.trim()) return;
    const cx = INSET + (tb.xPct / 100) * (mapW - INSET * 2);
    const cy = INSET + (tb.yPct / 100) * (mapH - INSET * 2);
    ec.save();
    ec.translate(cx, cy);
    ec.rotate(tb.rotation * Math.PI / 180);
    const isItalic = tb.fontStyle === 'italic';
    const isBold   = tb.fontStyle === 'bold';
    ec.font      = `${isItalic ? 'italic' : 'normal'} ${isBold ? 'bold' : 'normal'} ${tb.fontSize}px Georgia, serif`;
    ec.fillStyle = tb.color || '#111';
    ec.textAlign = 'center'; ec.textBaseline = 'middle';
    ec.fillText(text, 0, 0);
    ec.restore();
  });

  // Composite on-map title box onto export
  if (mapTitle && titleBoxEl.classList.contains('visible')) {
    const oRect = overlay.getBoundingClientRect();
    const tRect = titleBoxEl.getBoundingClientRect();
    const cScale = mapW / oRect.width;
    // Title box CSS uses translateX(-50%), so left% is the center
    const tCenterX = (tRect.left + tRect.right) / 2;
    const tx = INSET + (tCenterX - oRect.left) * cScale;
    const ty = INSET + (tRect.top - oRect.top)  * cScale;
    const titleFontSize = Math.round(mapH * 0.030);
    ec.font = `bold ${titleFontSize}px Georgia, serif`;
    const tw = ec.measureText(mapTitle).width;
    const pad = titleFontSize * 0.5;
    const bx = tx - tw / 2 - pad, bw = tw + pad * 2;
    const bh = titleFontSize * 1.6;
    // Cream background + border
    ec.fillStyle = '#faf6ee';
    ec.fillRect(bx, ty, bw, bh);
    ec.fillStyle = '#111';
    ec.fillRect(bx,          ty,          bw, 2.5); // top border
    ec.fillRect(bx,          ty + bh - 2.5, bw, 2.5); // bottom
    ec.fillRect(bx,          ty,          2.5, bh); // left
    ec.fillRect(bx + bw - 2.5, ty,        2.5, bh); // right
    // Title text
    ec.fillStyle = '#111';
    ec.textAlign = 'center'; ec.textBaseline = 'middle';
    ec.fillText(mapTitle, tx, ty + bh / 2);
  }

  if (allEntries.length > 0) {
    if (keyPlacement === 'onmap' && onmapKeyEl.classList.contains('visible')) {
      const oRect  = overlay.getBoundingClientRect();
      const kRect  = onmapKeyEl.getBoundingClientRect();
      const cScale = mapW / oRect.width;
      const kx     = INSET + (kRect.left - oRect.left) * cScale;
      const ky     = INSET + (kRect.top  - oRect.top)  * cScale;
      // Render at full map resolution to offscreen, then scale to match CSS box width
      const offC   = document.createElement('canvas');
      offC.width   = mapW; offC.height = mapH;
      const oc     = offC.getContext('2d');
      const { boxW, boxH } = renderKeyBoxAt(oc, 0, 0, allEntries);
      const scaledW = kRect.width * cScale;
      const scaledH = boxH * (scaledW / boxW);
      ec.drawImage(offC, 0, 0, boxW, boxH, kx, ky, scaledW, scaledH);
    } else {
      renderKeyBox(ec, mapW, mapH, allEntries);
    }
  }

  const link    = document.createElement('a');
  link.download = 'map.png';
  link.href     = exportCanvas.toDataURL('image/png');
  link.click();
}
// ── On-map Key Overlay ──────────────────────────────────────────────────────

let keyPlacement       = 'below';   // 'below' | 'onmap'
let onmapKeyCollapsed  = false;
let onmapKeyXPct       = 2;         // position as % of overlay width
let onmapKeyYPct       = 50;        // position as % of overlay height (center)
let onmapKeyWidthPx    = 200;       // current CSS width in pixels

const onmapKeyEl       = document.getElementById('onmap-key');
const onmapKeyBody     = document.getElementById('onmap-key-body');
const onmapKeyResizeEl = document.getElementById('onmap-key-resize');

function setKeyPlacement(mode) {
  keyPlacement = mode;
  document.getElementById('kplace-below').classList.toggle('active', mode === 'below');
  document.getElementById('kplace-onmap').classList.toggle('active', mode === 'onmap');
  if (mode === 'onmap') {
    onmapKeyEl.classList.add('visible');
    refreshOnmapKeyBody();
    positionOnmapKey();
  } else {
    onmapKeyEl.classList.remove('visible');
  }
}

function positionOnmapKey() {
  onmapKeyEl.style.left      = onmapKeyXPct + '%';
  onmapKeyEl.style.top       = onmapKeyYPct + '%';
  onmapKeyEl.style.transform = 'none';   // override initial translateY(-50%) after first drag
  onmapKeyEl.style.width     = onmapKeyWidthPx + 'px';
}

function refreshOnmapKeyBody() {
  onmapKeyBody.innerHTML = '';
  const entries = [...collectAutoKeyEntries(), ...keyManualEntries];

  if (entries.length === 0) {
    const hint = document.createElement('div');
    hint.className   = 'ok-empty-hint';
    hint.textContent = 'No key entries yet.';
    onmapKeyBody.appendChild(hint);
    return;
  }

  // Render via the same function used at export time — pixel-accurate live preview
  const offC = document.createElement('canvas');
  offC.width = 2000; offC.height = 1200;
  const { boxW, boxH } = renderKeyBoxAt(offC.getContext('2d'), 0, 0, entries);

  // Crop to actual key region
  const dispC = document.createElement('canvas');
  dispC.width  = boxW;
  dispC.height = boxH;
  dispC.getContext('2d').drawImage(offC, 0, 0, boxW, boxH, 0, 0, boxW, boxH);

  // Scale to fill the overlay box width exactly
  dispC.style.width   = '100%';
  dispC.style.height  = 'auto';
  dispC.style.display = 'block';

  onmapKeyBody.appendChild(dispC);
}

function toggleOnmapKeyCollapse() {
  onmapKeyCollapsed = !onmapKeyCollapsed;
  onmapKeyBody.style.display      = onmapKeyCollapsed ? 'none' : 'flex';
  onmapKeyResizeEl.style.display  = onmapKeyCollapsed ? 'none' : 'flex';
  document.getElementById('onmap-key-collapse').textContent = onmapKeyCollapsed ? '+' : '−';
}

// Drag header to reposition
(function() {
  const header = document.getElementById('onmap-key-header');
  let dragging = false, startX, startY, startXPct, startYPct;

  header.addEventListener('mousedown', e => {
    if (e.target.id === 'onmap-key-collapse') return;
    dragging = true;
    startX = e.clientX; startY = e.clientY;
    startXPct = onmapKeyXPct; startYPct = onmapKeyYPct;
    e.preventDefault();
  });
  document.addEventListener('mousemove', e => {
    if (!dragging) return;
    const oRect   = overlay.getBoundingClientRect();
    onmapKeyXPct  = startXPct + (e.clientX - startX) / oRect.width  * 100;
    onmapKeyYPct  = startYPct + (e.clientY - startY) / oRect.height * 100;
    onmapKeyXPct  = Math.max(0, Math.min(85, onmapKeyXPct));
    onmapKeyYPct  = Math.max(0, Math.min(90, onmapKeyYPct));
    positionOnmapKey();
  });
  document.addEventListener('mouseup', () => { dragging = false; });
})();

// Resize handle — drag bottom-right corner to change width
(function() {
  let resizing = false, startX, startW;
  onmapKeyResizeEl.addEventListener('mousedown', e => {
    resizing = true;
    startX = e.clientX;
    startW = onmapKeyWidthPx;
    e.preventDefault(); e.stopPropagation();
  });
  document.addEventListener('mousemove', e => {
    if (!resizing) return;
    onmapKeyWidthPx = Math.max(140, Math.min(480, startW + (e.clientX - startX)));
    onmapKeyEl.style.width = onmapKeyWidthPx + 'px';
    refreshOnmapKeyBody();
  });
  document.addEventListener('mouseup', () => { resizing = false; });
})();

// ── renderKeyBoxAt — renders the key at an arbitrary (ox, oy) on any canvas context ──

function renderKeyBoxAt(ec, ox, oy, entries) {
  const numCols   = Math.ceil(entries.length / KEY_MAX_ROWS);
  const numRows   = Math.min(entries.length, KEY_MAX_ROWS);

  ec.font = `${KEY_FONT_SIZE}px Georgia, serif`;
  const maxLabelW = entries.reduce((m, e) => Math.max(m, ec.measureText(e.label).width), 0);
  const colW  = KEY_ICON_BOX_W + KEY_ICON_LABEL_GAP + Math.ceil(maxLabelW) + KEY_COL_MARGIN;
  const boxW  = KEY_PAD + numCols * colW + KEY_PAD;
  const boxH  = KEY_PAD + KEY_TITLE_H   + numRows * KEY_ROW_H + KEY_PAD;

  // Background
  ec.fillStyle = '#faf6ee';
  ec.fillRect(ox, oy, boxW, boxH);

  // Border
  const KBW = 3;
  ec.strokeStyle = '#111'; ec.lineWidth = KBW;
  ec.strokeRect(ox + KBW/2, oy + KBW/2, boxW - KBW, boxH - KBW);

  // Title
  ec.fillStyle    = '#111';
  ec.font         = `bold ${KEY_FONT_SIZE + 4}px Georgia, serif`;
  ec.textAlign    = 'center';
  ec.textBaseline = 'middle';
  ec.fillText('Key', ox + boxW / 2, oy + KEY_PAD + KEY_TITLE_H / 2);

  // Divider
  ec.beginPath();
  ec.moveTo(ox + KEY_PAD, oy + KEY_PAD + KEY_TITLE_H);
  ec.lineTo(ox + boxW - KEY_PAD, oy + KEY_PAD + KEY_TITLE_H);
  ec.lineWidth = 1.5; ec.stroke();

  // Entries
  const itemsStartY = oy + KEY_PAD + KEY_TITLE_H + 8;
  entries.forEach((entry, i) => {
    const col    = Math.floor(i / KEY_MAX_ROWS);
    const row    = i % KEY_MAX_ROWS;
    const itemX  = ox + KEY_PAD + col * colW;
    const itemCY = itemsStartY + row * KEY_ROW_H + KEY_ROW_H / 2;
    drawKeyEntryIcon(ec, entry, itemX + KEY_ICON_BOX_W / 2, itemCY);
    ec.fillStyle    = '#111';
    ec.font         = `${KEY_FONT_SIZE}px Georgia, serif`;
    ec.textAlign    = 'left';
    ec.textBaseline = 'middle';
    ec.fillText(entry.label, itemX + KEY_ICON_BOX_W + KEY_ICON_LABEL_GAP, itemCY);
  });

  return { boxW, boxH };
}

// Initialise map library thumbnails now that MAP_LIBRARY is defined
buildMapLibrary();

// ── Custom-region hand-off ───────────────────────────────────────────────────
// The crop tool (crop-region-v1.html) stashes a cropped base map in
// sessionStorage, then navigates here. If one is waiting, load it straight
// into the canvas (treated like an uploaded map: not state-fillable) and skip
// the start screen entirely.
(function loadPendingCrop() {
  const HANDOFF_KEY = 'mapforge_pending_crop';
  let dataUrl;
  try { dataUrl = sessionStorage.getItem(HANDOFF_KEY); } catch (e) { return; }
  if (!dataUrl) return;
  sessionStorage.removeItem(HANDOFF_KEY);   // one-shot; don't reload on refresh
  loadMap(dataUrl, false);                  // img.onload sizes canvas + dismisses start screen
})();

// ── Label Panel ─────────────────────────────────────────────────────────────

let lpColor     = '#111111';
let lpFontSize  = 20;
let lpFontStyle = 'normal';
let lpDragging  = false;

function lpUpdatePreview() {
  const input   = document.getElementById('lp-input');
  const preview = document.getElementById('lp-preview');
  const ptext   = document.getElementById('lp-preview-text');
  const text    = input.value.trim();
  if (text) {
    ptext.textContent    = text;
    ptext.style.color    = lpColor;
    ptext.style.fontSize = lpFontSize + 'px';
    ptext.style.fontStyle  = (lpFontStyle === 'italic') ? 'italic' : 'normal';
    ptext.style.fontWeight = (lpFontStyle === 'bold')   ? 'bold'   : 'normal';
    preview.classList.remove('empty');
  } else {
    ptext.textContent      = 'label preview';
    ptext.style.color      = '#aaa';
    ptext.style.fontSize   = '13px';
    ptext.style.fontStyle  = 'italic';
    ptext.style.fontWeight = 'normal';
    preview.classList.add('empty');
  }
}

function lpSetColor(hex, el) {
  lpColor = hex;
  document.querySelectorAll('.lp-color-swatch').forEach(s => s.classList.remove('active'));
  el.classList.add('active');
  lpUpdatePreview();
}

function lpAdjustSize(delta) {
  lpFontSize = Math.max(8, Math.min(72, lpFontSize + delta));
  document.getElementById('lp-size-display').textContent = lpFontSize;
  lpUpdatePreview();
}

function lpSetStyle(style) {
  lpFontStyle = style;
  document.querySelectorAll('.lp-style-btn').forEach(b => b.classList.remove('active'));
  document.getElementById('lpbtn-' + style).classList.add('active');
  lpUpdatePreview();
}

// Drag from preview chip onto map
(function() {
  const preview = document.getElementById('lp-preview');
  const ghost   = document.getElementById('lp-ghost');

  preview.addEventListener('mousedown', e => {
    const text = document.getElementById('lp-input').value.trim();
    if (!text) return;
    lpDragging = true;

    ghost.textContent      = text;
    ghost.style.color      = lpColor;
    ghost.style.fontSize   = Math.min(lpFontSize, 22) + 'px'; // cap ghost size for readability
    ghost.style.fontStyle  = (lpFontStyle === 'italic') ? 'italic' : 'normal';
    ghost.style.fontWeight = (lpFontStyle === 'bold')   ? 'bold'   : 'normal';
    ghost.style.left       = e.clientX + 'px';
    ghost.style.top        = e.clientY + 'px';
    ghost.style.display    = 'block';
    e.preventDefault();
  });

  document.addEventListener('mousemove', e => {
    if (!lpDragging) return;
    ghost.style.left = e.clientX + 'px';
    ghost.style.top  = e.clientY + 'px';
  });

  document.addEventListener('mouseup', e => {
    if (!lpDragging) return;
    lpDragging = false;
    ghost.style.display = 'none';

    // Check drop is over the text overlay (which covers the canvas)
    const oRect = overlay.getBoundingClientRect();
    if (e.clientX >= oRect.left && e.clientX <= oRect.right &&
        e.clientY >= oRect.top  && e.clientY <= oRect.bottom) {
      const text = document.getElementById('lp-input').value.trim();
      if (!text) return;
      const xPct = (e.clientX - oRect.left) / oRect.width  * 100;
      const yPct = (e.clientY - oRect.top)  / oRect.height * 100;
      createTextBox(xPct, yPct, { text, fontSize: lpFontSize, color: lpColor, fontStyle: lpFontStyle });
    }
  });
})();
