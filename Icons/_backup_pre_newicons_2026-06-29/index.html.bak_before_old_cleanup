function drawSilk_OLD(ctx, x, y, size) {
  // Spool of silk thread — two flanged ends with wound thread in the middle
  ctx.save();
  ctx.strokeStyle = '#111'; ctx.fillStyle = '#111';
  const sw = size * 0.48;  // spool body half-width
  const ch = size * 0.20;  // core half-height (thread area)
  const fh = size * 0.35;  // flange half-height
  const ew = size * 0.10;  // flange ellipse x-radius

  // Spool body top & bottom edges
  ctx.lineWidth = 1.4; ctx.lineCap = 'butt';
  ctx.beginPath(); ctx.moveTo(x - sw, y - ch); ctx.lineTo(x + sw, y - ch); ctx.stroke();
  ctx.beginPath(); ctx.moveTo(x - sw, y + ch); ctx.lineTo(x + sw, y + ch); ctx.stroke();

  // Left flange (full ellipse)
  ctx.beginPath(); ctx.ellipse(x - sw, y, ew, fh, 0, 0, Math.PI * 2); ctx.stroke();
  // Right flange (full ellipse)
  ctx.beginPath(); ctx.ellipse(x + sw, y, ew, fh, 0, 0, Math.PI * 2); ctx.stroke();

  // Vertical thread lines on the spool body
  ctx.lineWidth = 0.9;
  [-0.45, -0.15, 0.15, 0.45].forEach(t => {
    ctx.beginPath();
    ctx.moveTo(x + t * sw * 1.8, y - ch);
    ctx.lineTo(x + t * sw * 1.8, y + ch);
    ctx.stroke();
  });

  // Small loose thread tail curling off the right side
  ctx.lineWidth = 1.1; ctx.lineCap = 'round';
  ctx.beginPath();
  ctx.moveTo(x + sw + ew * 0.6, y - fh * 0.3);
  ctx.quadraticCurveTo(x + sw + size * 0.38, y - fh * 0.9, x + sw + size * 0.22, y - fh * 1.1);
  ctx.stroke();

  ctx.restore();
}

function drawTextiles_OLD(ctx, x, y, size) {
  ctx.save();
  ctx.strokeStyle = '#111'; ctx.lineWidth = 1.5; ctx.lineJoin = 'round'; ctx.lineCap = 'round';
  const bw=size*0.52, bh=size*0.68, sw=size*0.3, sh=size*0.26, cw=size*0.18, cd=size*0.14, ty=y-bh*0.5;
  ctx.beginPath();
  ctx.moveTo(x-cw, ty); ctx.lineTo(x-bw-sw, ty); ctx.lineTo(x-bw-sw, ty+sh);
  ctx.lineTo(x-bw, ty+sh*0.7); ctx.lineTo(x-bw, ty+bh); ctx.lineTo(x+bw, ty+bh);
  ctx.lineTo(x+bw, ty+sh*0.7); ctx.lineTo(x+bw+sw, ty+sh); ctx.lineTo(x+bw+sw, ty);
  ctx.lineTo(x+cw, ty);
  ctx.quadraticCurveTo(x+cw*0.4, ty+cd, x, ty+cd);
  ctx.quadraticCurveTo(x-cw*0.4, ty+cd, x-cw, ty);
  ctx.closePath(); ctx.stroke();
  ctx.restore();
}

// ── Feature line drawing ─────────────────────────────────────────────────────

function pathPerps(points) {
  return points.map((p, i) => {
    let dx, dy;
    if (i === 0)                    { dx = points[1].x - p.x;             dy = points[1].y - p.y; }
    else if (i === points.length-1) { dx = p.x - points[i-1].x;           dy = p.y - points[i-1].y; }
    else                            { dx = points[i+1].x - points[i-1].x; dy = points[i+1].y - points[i-1].y; }
    const len = Math.sqrt(dx*dx + dy*dy) || 1;
    return { nx: -dy/len, ny: dx/len };
  });
}

function parallelPaths(points, offset) {
  const perps = pathPerps(points);
  const left  = points.map((p,i) => ({ x: p.x + perps[i].nx*offset, y: p.y + perps[i].ny*offset }));
  const right = points.map((p,i) => ({ x: p.x - perps[i].nx*offset, y: p.y - perps[i].ny*offset }));
  return { left, right };
}

function strokePath(ctx, pts) {
  ctx.beginPath(); ctx.moveTo(pts[0].x, pts[0].y);
  for (let i = 1; i < pts.length; i++) ctx.lineTo(pts[i].x, pts[i].y);
  ctx.stroke();
}

function walkPath(points, startOffset, spacing, fn) {
  let distAcc = 0, next = startOffset;
  for (let i = 1; i < points.length; i++) {
    const dx = points[i].x - points[i-1].x, dy = points[i].y - points[i-1].y;
    const segLen = Math.sqrt(dx*dx + dy*dy);
    if (segLen < 0.01) { distAcc += segLen; continue; }
    const angle = Math.atan2(dy, dx);
    while (distAcc + segLen >= next) {
      const t = (next - distAcc) / segLen;
      fn(points[i-1].x + dx*t, points[i-1].y + dy*t, angle);
      next += spacing;
    }
    distAcc += segLen;
  }
}

function drawWall(ctx, points, color) {
  if (points.length < 2) return;
  const baseHalf = 2, mW = 5, mH = 4, spacing = 14;
  ctx.save();
  ctx.fillStyle = ctx.strokeStyle = color || '#111';
  ctx.lineCap = 'butt'; ctx.lineJoin = 'miter';
  ctx.lineWidth = baseHalf * 2;
  strokePath(ctx, points);
  walkPath(points, spacing * 0.45, spacing, (x, y, angle) => {
    ctx.save(); ctx.translate(x, y); ctx.rotate(angle);
    ctx.fillRect(-mW/2,  baseHalf,       mW, mH);
    ctx.fillRect(-mW/2, -baseHalf - mH,  mW, mH);
    ctx.restore();
  });
  ctx.restore();
}

function drawRailroad(ctx, points, color) {
  if (points.length < 2) return;
  const railOff = 4, railW = 1.5, tieW = 2.5, tieExt = 2, spacing = 12;
  ctx.save();
  ctx.strokeStyle = color || '#111'; ctx.lineJoin = 'round';
  const { left, right } = parallelPaths(points, railOff);
  ctx.lineWidth = railW; ctx.lineCap = 'round';
  strokePath(ctx, left); strokePath(ctx, right);
  ctx.lineWidth = tieW; ctx.lineCap = 'butt';
  walkPath(points, spacing * 0.5, spacing, (x, y, angle) => {
    const ext = railOff + tieExt;
    const nx = -Math.sin(angle), ny = Math.cos(angle);
    ctx.beginPath(); ctx.moveTo(x+nx*ext, y+ny*ext); ctx.lineTo(x-nx*ext, y-ny*ext); ctx.stroke();
  });
  ctx.restore();
}

function drawCanal(ctx, points) {
  if (points.length < 2) return;
  // Two parallel black lines with white fill between — no water color
  const canalOff = 6, bankW = 2.5;
  ctx.save();
  const { left, right } = parallelPaths(points, canalOff);

  // White fill between the two lines
  ctx.beginPath();
  ctx.moveTo(left[0].x, left[0].y);
  for (let i = 1; i < left.length; i++) ctx.lineTo(left[i].x, left[i].y);
  for (let i = right.length - 1; i >= 0; i--) ctx.lineTo(right[i].x, right[i].y);
  ctx.closePath(); ctx.fillStyle = '#fff'; ctx.fill();

  // Two solid black lines
  ctx.strokeStyle = '#111'; ctx.lineWidth = bankW;
  ctx.lineCap = 'round'; ctx.lineJoin = 'round';
  strokePath(ctx, left); strokePath(ctx, right);
  ctx.restore();
}

function drawFeatureLine(ctx, points, type, color) {
  if      (type === 'feature-wall')     drawWall(ctx, points, color);
  else if (type === 'feature-railroad') drawRailroad(ctx, points, color);
  else if (type === 'feature-canal')    drawCanal(ctx, points);
}

const FEATURE_TYPES = new Set(['feature-wall', 'feature-railroad', 'feature-canal']);
function isFeatureStamp(t) { return FEATURE_TYPES.has(t); }

function drawWhaling_OLD(ctx, x, y, size) {
  // Blue whale — long streamlined silhouette, tiny dorsal fin set far back,
  // horizontal flukes, broad rounded head ~25% of length, throat pleats
  ctx.save();
  ctx.fillStyle = '#111'; ctx.strokeStyle = '#111';

  // Shift slightly left so long body fits the canvas well
  const ox = x - size * 0.04;

  // Main body outline — wide elongated shape
  ctx.beginPath();
  // Start at tail narrow point
  ctx.moveTo(ox + size * 0.78, y);
  // Upper back edge — sweeps to broad head
  ctx.bezierCurveTo(ox + size * 0.5,  y - size * 0.24,
                    ox - size * 0.2,  y - size * 0.30,
                    ox - size * 0.78, y - size * 0.06);
  // Head front — rounded blunt tip
  ctx.bezierCurveTo(ox - size * 0.92, y - size * 0.02,
                    ox - size * 0.92, y + size * 0.14,
                    ox - size * 0.78, y + size * 0.18);
  // Lower belly back to tail
  ctx.bezierCurveTo(ox - size * 0.2,  y + size * 0.28,
                    ox + size * 0.5,  y + size * 0.18,
                    ox + size * 0.78, y);
  ctx.closePath();
  ctx.fill();

  // Tail flukes — horizontal, two lobes spreading up and down
  ctx.beginPath();
  ctx.moveTo(ox + size * 0.72, y - size * 0.03);
  ctx.bezierCurveTo(ox + size * 0.82, y - size * 0.10, ox + size * 1.00, y - size * 0.28, ox + size * 0.98, y - size * 0.38);
  ctx.bezierCurveTo(ox + size * 0.96, y - size * 0.45, ox + size * 0.84, y - size * 0.32, ox + size * 0.76, y - size * 0.06);
  ctx.closePath(); ctx.fill();

  ctx.beginPath();
  ctx.moveTo(ox + size * 0.72, y + size * 0.03);
  ctx.bezierCurveTo(ox + size * 0.82, y + size * 0.10, ox + size * 1.00, y + size * 0.28, ox + size * 0.98, y + size * 0.38);
  ctx.bezierCurveTo(ox + size * 0.96, y + size * 0.45, ox + size * 0.84, y + size * 0.32, ox + size * 0.76, y + size * 0.06);
  ctx.closePath(); ctx.fill();

  // Tiny dorsal fin — set 2/3 back on the body (blue whale's distinguishing feature)
  ctx.beginPath();
  ctx.moveTo(ox + size * 0.28, y - size * 0.28);
  ctx.quadraticCurveTo(ox + size * 0.35, y - size * 0.46, ox + size * 0.46, y - size * 0.30);
  ctx.closePath(); ctx.fill();

  // Pectoral flipper — long, narrow, angled down-forward
  ctx.beginPath();
  ctx.moveTo(ox - size * 0.30, y + size * 0.14);
  ctx.bezierCurveTo(ox - size * 0.28, y + size * 0.36, ox - size * 0.02, y + size * 0.44, ox + size * 0.06, y + size * 0.28);
  ctx.bezierCurveTo(ox - size * 0.02, y + size * 0.20, ox - size * 0.18, y + size * 0.16, ox - size * 0.30, y + size * 0.14);
  ctx.fill();

  // White belly — large, characteristic of blue whales
  ctx.fillStyle = '#fff';
  ctx.beginPath();
  ctx.ellipse(ox - size * 0.16, y + size * 0.13, size * 0.38, size * 0.09, -0.1, 0, Math.PI * 2);
  ctx.fill();

  // Throat pleats (grooves) — 3 short lines on the belly
  ctx.strokeStyle = '#111'; ctx.lineWidth = 0.8; ctx.lineCap = 'round';
  [-size*0.12, 0, size*0.12].forEach(dx => {
    ctx.beginPath();
    ctx.moveTo(ox - size*0.38 + dx*0.3, y + size*0.12);
    ctx.lineTo(ox - size*0.10 + dx*0.3, y + size*0.20);
    ctx.stroke();
  });

  // Eye — small dot
  ctx.fillStyle = '#fff';
  ctx.beginPath(); ctx.arc(ox - size*0.62, y - size*0.04, size*0.045, 0, Math.PI*2); ctx.fill();

  ctx.restore();
}

function drawFish_OLD(ctx, x, y, size) {
