function updateKeyPreview() {
  const c = document.getElementById('km-preview');
  if (!c) return;
  const pc = c.getContext('2d');
  pc.clearRect(0, 0, 80, 40);
  pc.fillStyle = '#faf6ee';
  pc.fillRect(0, 0, 80, 40);

  if (keyModalType === 'line') {
    drawStroke(pc, [{x:8,y:20},{x:40,y:20},{x:72,y:20}], keyLineStyle, keyColor);
  } else if (keyModalType === 'arrow') {
    drawArrow(pc, 8, 20, 72, 20, 40, 12, keyColor);
  } else {
    // Show shade as a small filled rectangle (matches how it appears in the exported key)
    const rw = 60, rh = 24, rx = 10, ry = 8;
    const tmpC = document.createElement('canvas');
    tmpC.width = 80; tmpC.height = 40;
    const tc = tmpC.getContext('2d');
    if (keyShadeStyle === 'solid') {
      tc.fillStyle = keyColor;
      tc.fillRect(rx, ry, rw, rh);
    } else if (keyShadeStyle === 'stripe') {
      tc.fillStyle = makeStripePattern(tc, keyColor);
      tc.fillRect(rx, ry, rw, rh);
    } else if (keyShadeStyle === 'plus') {
      tc.fillStyle = lightenColor(keyColor, 0.52);
      tc.fillRect(rx, ry, rw, rh);
      tc.strokeStyle = keyColor; tc.lineWidth = 1; tc.lineCap = 'round';
      for (let dx = rx + 5; dx < rx + rw; dx += 8)
        for (let dy = ry + 5; dy < ry + rh; dy += 8)
          drawPlus(tc, dx, dy, 2.5);
    }
    pc.save(); pc.globalAlpha = SHADE_OPACITY; pc.drawImage(tmpC, 0, 0); pc.restore();
    pc.strokeStyle = '#111'; pc.lineWidth = 1.2;
    pc.strokeRect(rx, ry, rw, rh);
  }
}

