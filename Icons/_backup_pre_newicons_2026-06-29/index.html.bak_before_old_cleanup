const HANDLE_R = 10;

function redraw(preview) {
  if (!img.naturalWidth) return;
  ctx.clearRect(0, 0, canvas.width, canvas.height);
  ctx.drawImage(img, 0, 0);

  // Fill layer — rendered above base map, below shade and stamps
  renderFillStamps();
  if (fillCanvas) ctx.drawImage(fillCanvas, 0, 0);

  renderShadeStamps();

  stamps.forEach((s, i) => {
    if (s.type === 'shade') return;
    if (s.type === 'fill')  return;  // handled by renderFillStamps
    const sz = s.size || 22;
    if (s.type === 'mountain')          drawMountainIcon(ctx, s.x, s.y, sz, '#111');
    if (s.type === 'peak')              drawPeakIcon(ctx, s.x, s.y, sz * 1.3, '#111');
    if (s.type === 'city')              drawCityIcon(ctx, s.x, s.y, sz * (36/22), '#111');
    if (s.type === 'desert')            drawDesertIcon(ctx, s.x, s.y, 1, '#111');
    if (isTradeStamp(s.type))           TRADE_GOODS[s.type].draw(ctx, s.x, s.y, s.iconSize || iconStampSize);
    if (isReligionStamp(s.type))        { const r=RELIGIONS[s.type]; r.draw(ctx, s.x, s.y, s.iconSize || iconStampSize); }
    if (s.type === 'oasis')             drawOasis(ctx, s.x, s.y, (s.iconSize || iconStampSize) * 1.2);
    if (s.type === 'danger')            drawDanger(ctx, s.x, s.y, (s.iconSize || iconStampSize) * 1.2);
    if (s.type === 'battle')            drawBattle(ctx, s.x, s.y, (s.iconSize || iconStampSize) * 1.2);
    if (isLineStamp(s.type))            drawStroke(ctx, s.points, s.type, s.color);
    if (isFeatureStamp(s.type))         drawFeatureLine(ctx, s.points, s.type, s.color);
    if (isArrowStamp(s.type)) {
      drawArrow(ctx, s.x1, s.y1, s.x2, s.y2, s.cx, s.cy, s.color || '#111');
      if (i === selectedArrowIdx) {
        ctx.save();
        ctx.strokeStyle='#4a6fa5'; ctx.lineWidth=1.5; ctx.setLineDash([4,3]);
        ctx.beginPath(); ctx.moveTo(s.x1,s.y1); ctx.lineTo(s.cx,s.cy); ctx.stroke();
        ctx.beginPath(); ctx.moveTo(s.x2,s.y2); ctx.lineTo(s.cx,s.cy); ctx.stroke();
        ctx.setLineDash([]);
        ctx.fillStyle='#fff'; ctx.strokeStyle='#4a6fa5'; ctx.lineWidth=2;
        ctx.beginPath(); ctx.arc(s.cx, s.cy, HANDLE_R, 0, Math.PI*2);
        ctx.fill(); ctx.stroke(); ctx.restore();
      }
    }
  });

  if (preview) {
    const mx=(preview.x1+preview.x2)/2, my=(preview.y1+preview.y2)/2;
    ctx.globalAlpha=0.5;
    drawArrow(ctx,preview.x1,preview.y1,preview.x2,preview.y2,mx,my,activeColor);
    ctx.globalAlpha=1;
  }
}

// ── Text box system ──────────────────────────────────────────────────────────

function createTextBox(xPct, yPct, opts) {
  deselectTB();
  const id  = ++tbIdCounter;
  const el  = document.createElement('div');
  el.className = 'text-box selected';
  el.dataset.id = id;

  const rotateLine   = document.createElement('div'); rotateLine.className   = 'tb-rotate-line';
  const rotateHandle = document.createElement('div'); rotateHandle.className = 'tb-rotate-handle';
  rotateHandle.title = 'Drag to rotate';

  const content = document.createElement('div');
  content.className = 'tb-content';
  content.contentEditable = 'true';
  const fs   = (opts && opts.fontStyle) || currentFontStyle;
  const size = (opts && opts.fontSize)  || currentFontSize;
  const col  = (opts && opts.color)     || activeColor;
  content.style.fontSize = size + 'px';
  content.style.color    = col;
  applyFontStyleToEl(content, fs);
  content.setAttribute('spellcheck', 'false');
  if (opts && opts.text) content.textContent = opts.text;

  el.appendChild(rotateLine); el.appendChild(rotateHandle); el.appendChild(content);
  overlay.appendChild(el);

  const tb = { id, el, xPct, yPct, rotation: (opts && opts.rotation)||0,
               fontSize: size, color: col, fontStyle: fs };
  textBoxes.push(tb);
  undoLog.push({ kind: 'textbox', id });
  redoStack.length = 0;

  positionTB(tb);
  selectedTB = tb;
  bindTBEvents(tb, rotateHandle, content);
  setTimeout(() => content.focus(), 30);
  return tb;
}

function positionTB(tb) {
  tb.el.style.left      = tb.xPct + '%';
  tb.el.style.top       = tb.yPct + '%';
  tb.el.style.transform = `translate(-50%, -50%) rotate(${tb.rotation}deg)`;
}

function selectTB(tb) {
  deselectTB();
  selectedTB = tb;
  tb.el.classList.add('selected');
  currentFontSize  = tb.fontSize;
  currentFontStyle = tb.fontStyle || 'italic';
  document.getElementById('font-size-display').textContent = currentFontSize;
  document.getElementById('fsbtn-italic').classList.toggle('active', currentFontStyle === 'italic');
  document.getElementById('fsbtn-bold').classList.toggle('active',   currentFontStyle === 'bold');
}

function deselectTB() {
  if (!selectedTB) return;
  selectedTB.el.classList.remove('selected');
  selectedTB.el.querySelector('.tb-content').blur();
  selectedTB = null;
}

function removeTB(tb) {
  if (selectedTB === tb) selectedTB = null;
  tb.el.remove();
  const idx = textBoxes.findIndex(t => t.id === tb.id);
  if (idx !== -1) textBoxes.splice(idx, 1);
}

function bindTBEvents(tb, rotateHandle, content) {
  let dragging = false, dragStartX, dragStartY, origXPct, origYPct;

  content.addEventListener('mousedown', e => {
    // Eraser: remove this text box
    if (activeStamp === 'eraser') {
      const snapshot = snapshotTB(tb);
      undoLog.push({ kind: 'textbox-erase', snapshot });
      redoStack.length = 0;
      removeTB(tb);
      e.stopPropagation();
      return;
    }
    selectTB(tb);
    dragging = true; dragStartX = e.clientX; dragStartY = e.clientY;
    origXPct = tb.xPct; origYPct = tb.yPct;
    e.stopPropagation();
  });

  let rotating = false;
  rotateHandle.addEventListener('mousedown', e => {
    rotating = true; e.preventDefault(); e.stopPropagation();
  });

  document.addEventListener('mousemove', e => {
    if (dragging) {
      const r = overlay.getBoundingClientRect();
      tb.xPct = origXPct + (e.clientX - dragStartX) / r.width  * 100;
      tb.yPct = origYPct + (e.clientY - dragStartY) / r.height * 100;
      positionTB(tb);
    }
    if (rotating) {
      const r = overlay.getBoundingClientRect();
      const cx = r.left + tb.xPct/100 * r.width, cy = r.top + tb.yPct/100 * r.height;
      tb.rotation = Math.atan2(e.clientY-cy, e.clientX-cx) * 180/Math.PI + 90;
      positionTB(tb);
    }
  });
  document.addEventListener('mouseup', () => { dragging = false; rotating = false; });
}

function snapshotTB(tb) {
  return {
    id: tb.id, xPct: tb.xPct, yPct: tb.yPct, rotation: tb.rotation,
    fontSize: tb.fontSize, color: tb.color, fontStyle: tb.fontStyle,
    text: tb.el.querySelector('.tb-content').textContent
  };
}

// ── Undo / Redo ──────────────────────────────────────────────────────────────

function undo() {
  if (!undoLog.length) return;
  const action = undoLog.pop();
  if (action.kind === 'stamp') {
    const s = stamps.pop();
    redoStack.push({ kind: 'stamp', stamp: s });
    if (selectedArrowIdx >= stamps.length) selectedArrowIdx = null;
    redraw();
  } else if (action.kind === 'textbox') {
    const idx = textBoxes.findIndex(t => t.id === action.id);
    if (idx !== -1) {
      const tb = textBoxes[idx];
      const snap = snapshotTB(tb);
      redoStack.push({ kind: 'textbox-redo', snapshot: snap });
      removeTB(tb);
    }
  } else if (action.kind === 'textbox-erase') {
    // Undo an eraser delete: restore the text box
    redoStack.push({ kind: 'textbox-erase-redo', snapshot: action.snapshot });
    const snap = action.snapshot;
    createTextBox(snap.xPct, snap.yPct, snap);
    // createTextBox pushes to undoLog, pop that off since this is an undo restore
    undoLog.pop();
    deselectTB();
  }
}

function redo() {
  if (!redoStack.length) return;
  const action = redoStack.pop();
  if (action.kind === 'stamp') {
    stamps.push(action.stamp);
    undoLog.push({ kind: 'stamp', stamp: action.stamp });
    redraw();
  } else if (action.kind === 'textbox-redo') {
    const snap = action.snapshot;
    createTextBox(snap.xPct, snap.yPct, snap);
    deselectTB();
  } else if (action.kind === 'textbox-erase-redo') {
    const snap = action.snapshot;
    const tb = textBoxes.find(t => t.id === snap.id);
    if (tb) { undoLog.push({ kind:'textbox-erase', snapshot: snapshotTB(tb) }); removeTB(tb); }
  }
}

document.addEventListener('keydown', e => {
  if (e.target.classList.contains('tb-content')) return;
  if ((e.metaKey || e.ctrlKey) && e.shiftKey && e.key === 'z') { e.preventDefault(); redo(); return; }
  if ((e.metaKey || e.ctrlKey) && e.key === 'z') { e.preventDefault(); undo(); return; }
  if ((e.metaKey || e.ctrlKey) && e.key === 'y') { e.preventDefault(); redo(); }
});

document.addEventListener('mousedown', e => {
  if (selectedTB && !e.target.closest('.text-box') && !e.target.closest('#toolbar')) deselectTB();
});

// ── Eraser hit detection ─────────────────────────────────────────────────────

const ERASER_RADIUS = 25;

function eraseAt(x, y) {
  // Walk stamps in reverse, remove the first one hit
  for (let i = stamps.length - 1; i >= 0; i--) {
    const s = stamps[i];
    let hit = false;
    if (s.type === 'mountain' || s.type === 'peak' || s.type === 'city' || s.type === 'desert' || s.type === 'oasis' || s.type === 'danger' || s.type === 'battle' || isTradeStamp(s.type) || isReligionStamp(s.type)) {
      hit = Math.hypot(x - s.x, y - s.y) <= ERASER_RADIUS * 2;
    } else if (s.type === 'shade' || isLineStamp(s.type) || isFeatureStamp(s.type)) {
      hit = s.points.some(p => Math.hypot(x - p.x, y - p.y) <= ERASER_RADIUS);
    } else if (isArrowStamp(s.type)) {
      hit = Math.hypot(x - s.cx, y - s.cy) <= ERASER_RADIUS * 2 ||
            Math.hypot(x - s.x1, y - s.y1) <= ERASER_RADIUS ||
            Math.hypot(x - s.x2, y - s.y2) <= ERASER_RADIUS;
    }
    if (hit) {
      const [removed] = stamps.splice(i, 1);
      undoLog.push({ kind: 'stamp-erase', stamp: removed, idx: i });
      redoStack.length = 0;
      if (selectedArrowIdx === i) selectedArrowIdx = null;
      else if (selectedArrowIdx > i) selectedArrowIdx--;
      redraw();
      return;
    }
  }
}

// ── Canvas interactions ──────────────────────────────────────────────────────

let mode = 'idle';
let arrowStart = null;
let lastPaintX = null, lastPaintY = null;
const PAINT_SPACING = 30;
const LINE_SPACING  = 6;

function getCanvasPos(e) {
  const rect = canvas.getBoundingClientRect();
  return {
    x: (e.clientX - rect.left) * (canvas.width  / rect.width),
    y: (e.clientY - rect.top)  * (canvas.height / rect.height)
  };
}

function getOverlayPct(e) {
  const rect = overlay.getBoundingClientRect();
  return {
    xPct: (e.clientX - rect.left) / rect.width  * 100,
    yPct: (e.clientY - rect.top)  / rect.height * 100
  };
}

function dist(ax,ay,bx,by) { return Math.hypot(ax-bx, ay-by); }

canvas.addEventListener('mousedown', e => {
  const { x, y } = getCanvasPos(e);

  if (activeStamp === 'eraser') {
    eraseAt(x, y);
    return;
  }

  if (isLineStamp(activeStamp) || isFeatureStamp(activeStamp)) {
    const s = { type: activeStamp, points: [{x,y}], color: activeColor };
    stamps.push(s);
    undoLog.push({ kind: 'stamp', stamp: s });
    redoStack.length = 0;
    lastPaintX = x; lastPaintY = y;
    mode = 'painting-line'; redraw(); return;
  }

  if (isArrowStamp(activeStamp)) {
    for (let i = stamps.length-1; i >= 0; i--) {
      const s = stamps[i];
      if (isArrowStamp(s.type) && dist(x,y,s.cx,s.cy) <= HANDLE_R*2) {
        selectedArrowIdx = i; mode = 'dragging-handle'; redraw(); return;
      }
    }
    selectedArrowIdx = null; arrowStart = {x,y}; mode = 'drawing-arrow'; return;
  }

  if (activeStamp === 'desert') {
    const s = { type:'desert', x, y };
    stamps.push(s);
    undoLog.push({ kind:'stamp', stamp: s });
    redoStack.length = 0;
    lastPaintX = x; lastPaintY = y; mode = 'painting-desert'; redraw(); return;
  }

  if (activeStamp === 'shade') {
    const s = { type:'shade', color: activeColor, radius: shadeSize, shadeStyle, points:[{x,y}] };
    stamps.push(s);
    undoLog.push({ kind:'stamp', stamp: s });
    redoStack.length = 0;
    lastPaintX = x; lastPaintY = y; mode = 'painting-shade'; redraw(); return;
  }

  if (activeStamp === 'fill') {
    const s = { type:'fill', x, y, color: activeColor };
    stamps.push(s);
    undoLog.push({ kind:'stamp', stamp: s });
    redoStack.length = 0;
    redraw(); return;
  }

  // Single-click stamps (mountain, city, trade, oasis, danger, religion…)
  const isIconType = isTradeStamp(activeStamp) || isReligionStamp(activeStamp) || activeStamp === 'oasis' || activeStamp === 'danger' || activeStamp === 'battle';
  const s = { type: activeStamp, x, y, size: stampSize, ...(isIconType ? { iconSize: iconStampSize } : {}) };
  stamps.push(s);
  undoLog.push({ kind:'stamp', stamp: s });
  redoStack.length = 0;
  selectedArrowIdx = null;
  redraw();
});

canvas.addEventListener('mousemove', e => {
  const { x, y } = getCanvasPos(e);
  lastShadeMouseE = e;
  if (activeStamp === 'shade') updateShadeCursor(e);

  if (mode === 'drawing-arrow' && arrowStart) {
    redraw({ x1:arrowStart.x, y1:arrowStart.y, x2:x, y2:y }); return;
  }
  if (mode === 'dragging-handle' && selectedArrowIdx !== null) {
    stamps[selectedArrowIdx].cx = x; stamps[selectedArrowIdx].cy = y; redraw(); return;
  }
  if (mode === 'painting-desert') {
    if (dist(x,y,lastPaintX,lastPaintY) >= PAINT_SPACING) {
      const s = { type:'desert', x, y };
      stamps.push(s); undoLog.push({ kind:'stamp', stamp: s });
      lastPaintX=x; lastPaintY=y; redraw();
    }
  }
  if (mode === 'painting-line') {
    if (dist(x,y,lastPaintX,lastPaintY) >= LINE_SPACING) {
      stamps[stamps.length-1].points.push({x,y});
      lastPaintX=x; lastPaintY=y; redraw();
    }
  }
  if (mode === 'painting-shade') {
    const spacing = Math.max(SHADE_SPACING, shadeSize * 0.18);
    if (dist(x,y,lastPaintX,lastPaintY) >= spacing) {
      stamps[stamps.length-1].points.push({x,y});
      lastPaintX=x; lastPaintY=y; redraw();
    }
  }
});

canvas.addEventListener('mouseup', e => {
  const { x, y } = getCanvasPos(e);
  if (mode === 'drawing-arrow' && arrowStart) {
    if (dist(x,y,arrowStart.x,arrowStart.y) > 10) {
      const cx=(arrowStart.x+x)/2, cy=(arrowStart.y+y)/2;
      const s = { type:activeStamp, x1:arrowStart.x, y1:arrowStart.y, x2:x, y2:y, cx, cy, color:activeColor };
      stamps.push(s);
      undoLog.push({ kind:'stamp', stamp: s });
      redoStack.length = 0;
      selectedArrowIdx = stamps.length-1;
    }
    arrowStart = null;
  }
  mode = 'idle'; redraw();
});

canvas.addEventListener('mouseleave', () => {
  mode='idle'; arrowStart=null; redraw();
  document.getElementById('shade-cursor').style.display = 'none';
});

