}

function drawArrow(ctx, x1, y1, x2, y2, cx, cy, color) {
  const col = color || '#111111';
  const angle = Math.atan2(y2-cy, x2-cx);
  ctx.save();
  ctx.lineJoin = 'round'; ctx.lineCap = 'round';
  ctx.strokeStyle = col; ctx.lineWidth = 9;
  ctx.beginPath(); ctx.moveTo(x1,y1);
  ctx.quadraticCurveTo(cx,cy,x2,y2); ctx.stroke();
  ctx.fillStyle = col;
  ctx.beginPath(); ctx.moveTo(x2,y2);
  ctx.lineTo(x2-28*Math.cos(angle-Math.PI/6), y2-28*Math.sin(angle-Math.PI/6));
  ctx.lineTo(x2-28*Math.cos(angle+Math.PI/6), y2-28*Math.sin(angle+Math.PI/6));
  ctx.closePath(); ctx.fill(); ctx.restore();
}

const LINE_DASH = {
  'line-solid':   [],
  'line-dotted':  [3, 18],
  'line-dashed':  [30, 20],
  'line-dashdot': [30, 14, 3, 14],
};
function isLineStamp(t) { return t in LINE_DASH; }
function isArrowStamp(t) { return t === 'arrow-black'; }

function drawStroke(ctx, points, type, color) {
  if (points.length < 2) return;
  ctx.save();
  ctx.strokeStyle = color || '#111111';
  ctx.lineWidth = 9; ctx.lineCap = 'round'; ctx.lineJoin = 'round';
  ctx.setLineDash(LINE_DASH[type] || []);
  ctx.beginPath(); ctx.moveTo(points[0].x, points[0].y);
  for (let i=1; i<points.length; i++) ctx.lineTo(points[i].x, points[i].y);
  ctx.stroke(); ctx.setLineDash([]); ctx.restore();
}

