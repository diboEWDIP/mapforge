function hexToRgbArr(hex) {
  // Returns [r, g, b] integers from a '#rrggbb' hex color string
  return [parseInt(hex.slice(1,3),16), parseInt(hex.slice(3,5),16), parseInt(hex.slice(5,7),16)];
}

// Build the pixel source for flood fill: base map + any drawn line/feature stamps.
// This means teacher-drawn lines (solid, dashed, dotted) also act as fill barriers,
// making it possible to fill custom regions on world maps.
function buildFillSourceCanvas() {
  const W = canvas.width, H = canvas.height;
  const tc = document.createElement('canvas');
  tc.width = W; tc.height = H;
  const tx = tc.getContext('2d');
  tx.drawImage(img, 0, 0);
  // Overlay any drawn line or feature stamps — these act as additional boundaries
  stamps.forEach(s => {
    if (isLineStamp(s.type))    drawStroke(tx, s.points, s.type, s.color);
    if (isFeatureStamp(s.type)) drawFeatureLine(tx, s.points, s.type, s.color);
  });
  return tx.getImageData(0, 0, W, H).data;
}

function floodFill(srcPx, W, H, startX, startY, fillR, fillG, fillB) {
  // Returns a Uint8ClampedArray (RGBA, same W×H as srcPx) with fill pixels set
  // and everything else transparent (alpha = 0).
  const out  = new Uint8ClampedArray(W * H * 4);  // all transparent initially
  const idx  = (x, y) => (y * W + x) * 4;
  const si   = idx(startX, startY);
  const seedR = srcPx[si], seedG = srcPx[si+1], seedB = srcPx[si+2];

  // Refuse to fill boundary / water / blocked-territory pixels
  if (seedR < 100 && seedG < 100 && seedB < 100) return out;           // dark lines
  if (seedB > 130 && (seedB-seedR) > 20 && (seedB-seedG) > 5) return out; // water
  if (seedR>175 && seedR<235 && seedG>175 && seedG<235 && seedB>175 && seedB<235
      && Math.abs(seedR-seedG)<12 && Math.abs(seedR-seedB)<12) return out; // blocked territory
  // Refuse to fill mid-grey pixels — catches state/province lines (~#aaa = 170)
  // so accidentally clicking a line doesn't flood-fill all connected grey lines
  if (seedR > 130 && seedR < 200 && Math.abs(seedR-seedG) < 20 && Math.abs(seedR-seedB) < 20) return out;

  const TOL     = 28;
  const visited = new Uint8Array(W * H);

  const matches = (x, y) => {
    if (visited[y * W + x]) return false;
    const i = idx(x, y);
    return Math.abs(srcPx[i]   - seedR) <= TOL &&
           Math.abs(srcPx[i+1] - seedG) <= TOL &&
           Math.abs(srcPx[i+2] - seedB) <= TOL;
  };

  const stack = [[startX, startY]];
  while (stack.length) {
    const [cx, cy] = stack.pop();
    if (cx < 0 || cx >= W || cy < 0 || cy >= H || !matches(cx, cy)) continue;

    let x = cx;
    while (x > 0 && matches(x - 1, cy)) x--;       // walk left to span start

    while (x < W && matches(x, cy)) {               // fill span rightward
      visited[cy * W + x] = 1;
      const i = idx(x, cy);
      out[i] = fillR; out[i+1] = fillG; out[i+2] = fillB; out[i+3] = 255;
      if (cy > 0     && matches(x, cy - 1)) stack.push([x, cy - 1]);
      if (cy < H - 1 && matches(x, cy + 1)) stack.push([x, cy + 1]);
      x++;
    }
  }
  return out;
}

function renderFillStamps() {
  if (!fillCanvas) return;
  const W = canvas.width, H = canvas.height;
  const fc = fillCanvas.getContext('2d');
  fc.clearRect(0, 0, W, H);

  const fills = stamps.filter(s => s.type === 'fill');
  if (!fills.length) return;

  // Build source pixels: base map + drawn lines (barriers for flood fill)
  const srcPx = buildFillSourceCanvas();

  // Render each fill into its own buffer then layer onto fillCanvas
  fills.forEach(s => {
    const [r, g, b] = hexToRgbArr(s.color);
    const buf  = floodFill(srcPx, W, H, Math.round(s.x), Math.round(s.y), r, g, b);
    const id   = new ImageData(buf, W, H);
    const tmpC = document.createElement('canvas');
    tmpC.width = W; tmpC.height = H;
    tmpC.getContext('2d').putImageData(id, 0, 0);
    fc.drawImage(tmpC, 0, 0);   // layer fill onto fillCanvas
  });
}
let lastShadeMouseE = null;

function buildLandMask(srcImg) {
  const mc = document.createElement('canvas');
  mc.width = srcImg.naturalWidth; mc.height = srcImg.naturalHeight;
  const mx = mc.getContext('2d');
  mx.drawImage(srcImg, 0, 0);
  const id = mx.getImageData(0, 0, mc.width, mc.height), px = id.data;
  for (let i = 0; i < px.length; i += 4) {
    const r = px[i], g = px[i+1], b = px[i+2];
    const isDark    = r < 100 && g < 100 && b < 100;
    const isWater   = b > 130 && (b-r) > 20 && (b-g) > 5;
    // Neutral mid-grey (175–235, nearly equal r/g/b) = "blocked territory" marker
    // Used to paint foreign land (Canada, Mexico) on maps where shading should stop
    // at the political border. Doesn't affect cream land (#faf6ee) or white (#fff).
    const isBlocked = r > 175 && r < 235 && g > 175 && g < 235 && b > 175 && b < 235
                      && Math.abs(r-g) < 12 && Math.abs(r-b) < 12 && Math.abs(g-b) < 12;
    if (isDark || isWater || isBlocked) { px[i]=px[i+1]=px[i+2]=0; px[i+3]=0; }
    else                                { px[i]=px[i+1]=px[i+2]=255; px[i+3]=255; }
  }
  mx.putImageData(id, 0, 0);
  return mc;
}

// Blend hex color toward white by amount (0=unchanged, 1=white)
function lightenColor(hex, amount) {
  let r = parseInt(hex.slice(1,3),16) || 0;
  let g = parseInt(hex.slice(3,5),16) || 0;
  let b = parseInt(hex.slice(5,7),16) || 0;
  r = Math.round(r + (255-r)*amount);
  g = Math.round(g + (255-g)*amount);
  b = Math.round(b + (255-b)*amount);
  return `rgb(${r},${g},${b})`;
}

// 45° diagonal stripe tile — equal-width alternating bands of color + lighter color
function makeStripePattern(ctx, color) {
  const light = lightenColor(color, 0.42);  // noticeably lighter but still recognisably the same hue
  const W = 24;          // width of each stripe (px) — clearly visible
  const N = W * 2;       // tile size = one full stripe pair
  const tile = document.createElement('canvas');
  tile.width = tile.height = N;
  const tc = tile.getContext('2d');

  // Fill tile with base color
  tc.fillStyle = color;
  tc.fillRect(0, 0, N, N);

  // Light stripe: two right-triangles at opposite corners tile into a
  // continuous diagonal band running at 45° (top-left → bottom-right)
  tc.fillStyle = light;
  // Top-left corner triangle
  tc.beginPath();
  tc.moveTo(0, 0); tc.lineTo(W, 0); tc.lineTo(0, W);
  tc.closePath(); tc.fill();
  // Bottom-right corner triangle
  tc.beginPath();
  tc.moveTo(W, N); tc.lineTo(N, N); tc.lineTo(N, W);
  tc.closePath(); tc.fill();

  return ctx.createPattern(tile, 'repeat');
}

// Draw small plus sign at (x,y) with arm half-length r
function drawPlus(ctx, x, y, r) {
  ctx.beginPath();
  ctx.moveTo(x-r, y); ctx.lineTo(x+r, y);
  ctx.moveTo(x, y-r); ctx.lineTo(x, y+r);
  ctx.stroke();
}

function renderShadeStamps() {
  if (!landMaskCanvas || !shadeTmpCanvas) return;
  const W = canvas.width, H = canvas.height;
  const stc = shadeTmpCanvas.getContext('2d');

  stc.clearRect(0, 0, W, H);
  stc.globalCompositeOperation = 'source-over';

  stamps.forEach(s => {
    if (s.type !== 'shade') return;
    const style = s.shadeStyle || 'solid';

    if (style === 'solid') {
      stc.fillStyle = s.color;
      s.points.forEach(({x,y}) => {
        stc.beginPath(); stc.arc(x, y, s.radius, 0, Math.PI*2); stc.fill();
      });
    } else if (style === 'stripe') {
      const pat = makeStripePattern(stc, s.color);
      stc.fillStyle = pat;
      s.points.forEach(({x,y}) => {
        stc.beginPath(); stc.arc(x, y, s.radius, 0, Math.PI*2); stc.fill();
      });
    } else if (style === 'plus') {
      const light = lightenColor(s.color, 0.52);
      // Fill with lighter color
      stc.fillStyle = light;
      s.points.forEach(({x,y}) => {
        stc.beginPath(); stc.arc(x, y, s.radius, 0, Math.PI*2); stc.fill();
      });
      // Draw plus marks on a grid where inside any painted circle
      stc.strokeStyle = s.color;
      stc.lineWidth = 1.5;
      stc.lineCap = 'round';
      const spacing = 14;
      let x1=Infinity, y1=Infinity, x2=-Infinity, y2=-Infinity;
      s.points.forEach(p => {
        x1=Math.min(x1,p.x-s.radius); y1=Math.min(y1,p.y-s.radius);
        x2=Math.max(x2,p.x+s.radius); y2=Math.max(y2,p.y+s.radius);
      });
      const r2 = s.radius * s.radius;
      for (let gx = Math.ceil(x1/spacing)*spacing; gx <= x2; gx += spacing) {
        for (let gy = Math.ceil(y1/spacing)*spacing; gy <= y2; gy += spacing) {
          for (const p of s.points) {
            if ((gx-p.x)**2 + (gy-p.y)**2 <= r2) { drawPlus(stc, gx, gy, 4); break; }
          }
        }
      }
    }
  });

  stc.globalCompositeOperation = 'destination-in';
  stc.drawImage(landMaskCanvas, 0, 0);

  ctx.save();
  ctx.globalAlpha = SHADE_OPACITY;
  ctx.globalCompositeOperation = 'source-over';
  ctx.drawImage(shadeTmpCanvas, 0, 0);
  ctx.restore();
}

function updateShadeCursor(e) {
  const el = document.getElementById('shade-cursor');
  document.getElementById('shade-size-display').textContent = shadeSize;
  if (!e || activeStamp !== 'shade') { el.style.display = 'none'; return; }
  const wrap = document.getElementById('canvas-wrap');
  const wr   = wrap.getBoundingClientRect();
  const diam = shadeSize * 2 * (canvas.clientWidth / canvas.width);
  el.style.width  = diam + 'px';
  el.style.height = diam + 'px';
  el.style.left   = (e.clientX - wr.left) + 'px';
  el.style.top    = (e.clientY - wr.top)  + 'px';
  el.style.display = 'block';
  el.style.borderColor = activeColor === '#111111' ? 'rgba(0,0,0,0.6)' : activeColor + 'cc';
}

