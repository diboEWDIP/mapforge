function openKeyAddTab() {
  document.getElementById('kmtab-add').classList.add('active');
  document.getElementById('kmtab-edit').classList.remove('active');
  document.getElementById('km-edit').style.display = 'none';
  showKeyForm();
}

function openKeyEditTab() {
  document.getElementById('kmtab-add').classList.remove('active');
  document.getElementById('kmtab-edit').classList.add('active');
  document.getElementById('km-form').style.display    = 'none';
  document.getElementById('km-addmore').style.display = 'none';
  document.getElementById('km-edit').style.display    = 'block';

  const all  = [...collectAutoKeyEntries(), ...keyManualEntries];
  const list = document.getElementById('km-edit-list');
  list.innerHTML = '';

  if (!all.length) {
    list.innerHTML = '<p style="color:#8a7050;text-align:center;padding:10px;font-size:12px;font-family:Georgia,serif;font-style:italic">No key entries yet.</p>';
    document.getElementById('km-remove-btn').disabled = true;
    return;
  }

  all.forEach(entry => {
    const row = document.createElement('div');
    row.className = 'km-edit-row';

    const cb = document.createElement('input');
    cb.type = 'checkbox';
    cb.dataset.entryId = entry.id;
    cb.addEventListener('change', updateRemoveBtn);

    const inp = document.createElement('input');
    inp.type = 'text';
    inp.className = 'km-label-input';
    // Show the current custom label or the default label
    inp.value = keyCustomLabels[entry.id] || entry.label;
    inp.title = 'Rename this key entry';
    inp.addEventListener('input', () => {
      const val = inp.value.trim();
      if (val && val !== entry.label) {
        keyCustomLabels[entry.id] = val;
      } else {
        delete keyCustomLabels[entry.id];
      }
      refreshOnmapKeyBody();
    });
    // Clicking the input should not toggle the checkbox
    inp.addEventListener('click', e => e.stopPropagation());

    row.appendChild(cb);
    row.appendChild(inp);
    list.appendChild(row);
  });

  updateRemoveBtn();
}

function updateRemoveBtn() {
  const any = !!document.querySelector('#km-edit-list input[type=checkbox]:checked');
  document.getElementById('km-remove-btn').disabled = !any;
}

function removeSelectedKeyEntries() {
  document.querySelectorAll('#km-edit-list input[type=checkbox]:checked').forEach(cb => {
    const id = cb.dataset.entryId;
    if (id.startsWith('manual-')) {
      const idx = keyManualEntries.findIndex(e => e.id === id);
      if (idx !== -1) keyManualEntries.splice(idx, 1);
    } else {
      keySuppressedTypes.add(id);
    }
  });
  openKeyEditTab();
  refreshOnmapKeyBody();
}

