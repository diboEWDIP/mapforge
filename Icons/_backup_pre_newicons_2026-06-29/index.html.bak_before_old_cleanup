function drawSpices_OLD(ctx, x, y, size) {
  // Two cinnamon sticks (3D cylinders) + a small vanilla flower
  ctx.save();
  ctx.strokeStyle = '#111'; ctx.lineCap = 'round';

  function cinnamonStick(cx, cy, angle) {
    const len = size*0.58, r = size*0.095;
    const cos = Math.cos(angle), sin = Math.sin(angle);
    const nx = -sin*r, ny = cos*r;
    const ax = cos*len/2, ay = sin*len/2;
    // Side edges
    ctx.lineWidth = 1.4;
    ctx.beginPath();
    ctx.moveTo(cx-ax+nx, cy-ay+ny); ctx.lineTo(cx+ax+nx, cy+ay+ny); ctx.stroke();
    ctx.beginPath();
    ctx.moveTo(cx-ax-nx, cy-ay-ny); ctx.lineTo(cx+ax-nx, cy+ay-ny); ctx.stroke();
    // End cap ellipses
    ctx.beginPath(); ctx.ellipse(cx+ax, cy+ay, r, r*0.38, angle+Math.PI/2, 0, Math.PI*2); ctx.stroke();
    ctx.beginPath(); ctx.ellipse(cx-ax, cy-ay, r, r*0.38, angle+Math.PI/2, 0, Math.PI*2); ctx.stroke();
    // Interior spiral lines (rolled bark texture)
    ctx.lineWidth = 0.75;
    [-0.28, 0, 0.28].forEach(t => {
      ctx.beginPath();
      ctx.ellipse(cx+cos*len*t, cy+sin*len*t, r*0.72, r*0.28, angle+Math.PI/2, 0, Math.PI*2);
      ctx.stroke();
    });
  }

  cinnamonStick(x - size*0.25, y + size*0.2,  Math.PI*0.12);
  cinnamonStick(x + size*0.2,  y + size*0.25, -Math.PI*0.08);

  // Vanilla flower — small 5-petal flower above the sticks
  const fx = x + size*0.02, fy = y - size*0.3;
  ctx.lineWidth = 1.2;
  for (let i = 0; i < 5; i++) {
    const a = (i/5)*Math.PI*2 - Math.PI/2;
    ctx.beginPath();
    ctx.ellipse(fx+Math.cos(a)*size*0.19, fy+Math.sin(a)*size*0.19, size*0.1, size*0.065, a, 0, Math.PI*2);
    ctx.stroke();
  }
  ctx.beginPath(); ctx.arc(fx, fy, size*0.07, 0, Math.PI*2); ctx.stroke();
  // Short stem to flower
  ctx.lineWidth = 1.2;
  ctx.beginPath(); ctx.moveTo(fx, fy+size*0.28); ctx.lineTo(fx, fy+size*0.38); ctx.stroke();

  ctx.restore();
}

function drawPerfume_OLD(ctx, x, y, size) {
  // 3D black outline perfume bottle — rounded rectangular body, narrow neck, flat stopper
  ctx.save();
  ctx.strokeStyle = '#111'; ctx.lineWidth = 1.5; ctx.lineCap = 'round'; ctx.lineJoin = 'round';

  const bw = size*0.5, bh = size*0.5, r = size*0.08;
  const by = y + size*0.2;   // body center y
  const nw = size*0.18, nh = size*0.22;

  // Rounded body
  ctx.beginPath();
  ctx.moveTo(x - bw/2 + r, by - bh/2);
  ctx.lineTo(x + bw/2 - r, by - bh/2);
  ctx.quadraticCurveTo(x + bw/2, by - bh/2, x + bw/2, by - bh/2 + r);
  ctx.lineTo(x + bw/2, by + bh/2 - r);
  ctx.quadraticCurveTo(x + bw/2, by + bh/2, x + bw/2 - r, by + bh/2);
  ctx.lineTo(x - bw/2 + r, by + bh/2);
  ctx.quadraticCurveTo(x - bw/2, by + bh/2, x - bw/2, by + bh/2 - r);
  ctx.lineTo(x - bw/2, by - bh/2 + r);
  ctx.quadraticCurveTo(x - bw/2, by - bh/2, x - bw/2 + r, by - bh/2);
  ctx.closePath(); ctx.stroke();

  // Neck
  ctx.beginPath();
  ctx.moveTo(x - nw/2, by - bh/2);
  ctx.lineTo(x - nw/2, by - bh/2 - nh);
  ctx.lineTo(x + nw/2, by - bh/2 - nh);
  ctx.lineTo(x + nw/2, by - bh/2);
  ctx.stroke();

  // Flat collar between neck and stopper
  ctx.beginPath();
  ctx.moveTo(x - nw/2 - size*0.04, by - bh/2 - nh);
  ctx.lineTo(x + nw/2 + size*0.04, by - bh/2 - nh);
  ctx.stroke();

  // Stopper — small rounded rectangle on top
  const sw = nw*0.9, sh = size*0.13;
  const sy = by - bh/2 - nh - sh;
  ctx.beginPath(); ctx.roundRect(x - sw/2, sy, sw, sh, size*0.03); ctx.stroke();

  // Label rectangle on body
  ctx.lineWidth = 0.9;
  ctx.strokeRect(x - bw*0.28, by - bh*0.22, bw*0.56, bh*0.38);

  ctx.restore();
}

function drawIncense_OLD(ctx, x, y, size) {
  // Thurible / censer — hanging incense burner
  ctx.save();
  ctx.strokeStyle = '#111'; ctx.lineCap = 'round'; ctx.lineJoin = 'round';

  // Chain (single line with small elliptical links)
  ctx.lineWidth = 1.3;
  ctx.beginPath(); ctx.moveTo(x, y - size*0.68); ctx.lineTo(x, y - size*0.34); ctx.stroke();
  ctx.lineWidth = 0.85;
  for (let ly = y - size*0.62; ly < y - size*0.34; ly += size*0.12) {
    ctx.beginPath(); ctx.ellipse(x, ly, size*0.045, size*0.036, 0, 0, Math.PI*2); ctx.stroke();
  }

  // Lid — arched dome with vent holes
  ctx.lineWidth = 1.4;
  const lidY = y - size*0.34;
  ctx.beginPath();
  ctx.moveTo(x - size*0.28, lidY);
  ctx.quadraticCurveTo(x, lidY - size*0.18, x + size*0.28, lidY);
  ctx.stroke();
  // Lid vents
  ctx.lineWidth = 0.85;
  [-0.14, 0, 0.14].forEach(ox => {
    ctx.beginPath(); ctx.arc(x + ox*size, lidY - size*0.07, size*0.03, 0, Math.PI*2); ctx.stroke();
  });

  // Body — bowl shape, wider at equator, narrowing to flat bottom
  ctx.lineWidth = 1.4;
  ctx.beginPath();
  ctx.moveTo(x - size*0.28, lidY);
  ctx.bezierCurveTo(x - size*0.34, lidY + size*0.2, x - size*0.32, lidY + size*0.45, x - size*0.12, lidY + size*0.62);
  ctx.lineTo(x + size*0.12, lidY + size*0.62);
  ctx.bezierCurveTo(x + size*0.32, lidY + size*0.45, x + size*0.34, lidY + size*0.2, x + size*0.28, lidY);
  ctx.stroke();
  // Bottom flat edge
  ctx.beginPath(); ctx.moveTo(x - size*0.12, lidY + size*0.62); ctx.lineTo(x + size*0.12, lidY + size*0.62); ctx.stroke();

  // Decorative perforations on body
  ctx.lineWidth = 0.85;
  [[-0.2, 0.18], [0.2, 0.18], [-0.24, 0.36], [0, 0.28], [0.24, 0.36]].forEach(([ox, oy]) => {
    ctx.beginPath(); ctx.arc(x + ox*size, lidY + oy*size, size*0.035, 0, Math.PI*2); ctx.stroke();
  });

  ctx.restore();
}

function drawShipbuilding_OLD(ctx, x, y, size) {
  // Solid black boat anchor
  ctx.save();
  ctx.fillStyle = '#111'; ctx.strokeStyle = '#111';
  ctx.lineWidth = 2; ctx.lineCap = 'round'; ctx.lineJoin = 'round';

  // Ring at top
  ctx.beginPath(); ctx.arc(x, y - size*0.5, size*0.13, 0, Math.PI*2); ctx.stroke();

  // Vertical shaft
  ctx.beginPath(); ctx.moveTo(x, y - size*0.37); ctx.lineTo(x, y + size*0.46); ctx.stroke();

  // Horizontal stock (crossbar near top)
  ctx.lineWidth = 2;
  ctx.beginPath(); ctx.moveTo(x - size*0.38, y - size*0.22); ctx.lineTo(x + size*0.38, y - size*0.22); ctx.stroke();

  // Curved arms
  ctx.lineWidth = 1.8;
  ctx.beginPath();
  ctx.moveTo(x, y + size*0.46);
  ctx.bezierCurveTo(x - size*0.08, y + size*0.28, x - size*0.46, y + size*0.32, x - size*0.48, y + size*0.14);
  ctx.stroke();
  ctx.beginPath();
  ctx.moveTo(x, y + size*0.46);
  ctx.bezierCurveTo(x + size*0.08, y + size*0.28, x + size*0.46, y + size*0.32, x + size*0.48, y + size*0.14);
  ctx.stroke();

  // Flukes (filled triangular barbs)
  ctx.beginPath();
  ctx.moveTo(x - size*0.48, y + size*0.14);
  ctx.lineTo(x - size*0.62, y + size*0.24);
  ctx.lineTo(x - size*0.38, y + size*0.3);
  ctx.closePath(); ctx.fill();
  ctx.beginPath();
  ctx.moveTo(x + size*0.48, y + size*0.14);
  ctx.lineTo(x + size*0.62, y + size*0.24);
  ctx.lineTo(x + size*0.38, y + size*0.3);
  ctx.closePath(); ctx.fill();

  ctx.restore();
}

function drawMountainPass(ctx, x, y, size) {
  // Mountain range silhouette with saddle/pass in the center
  ctx.save();
  ctx.fillStyle = '#111';
  ctx.beginPath();
  ctx.moveTo(x - size*0.68, y + size*0.42);
  ctx.lineTo(x - size*0.28, y - size*0.52);
  ctx.lineTo(x,              y - size*0.1);
  ctx.lineTo(x + size*0.28,  y - size*0.52);
  ctx.lineTo(x + size*0.68,  y + size*0.42);
  ctx.closePath();
  ctx.fill();
  // White dot at saddle marking the pass
  ctx.fillStyle = '#fff';
  ctx.beginPath(); ctx.arc(x, y - size*0.1, size*0.08, 0, Math.PI*2); ctx.fill();
  ctx.restore();
}

function drawChristianity_OLD(ctx, x, y, size) {
  // Solid black cross
  ctx.save();
  ctx.fillStyle = '#111';
  const aw = size * 0.22;
  ctx.fillRect(x - aw/2, y - size*0.62, aw, size*1.24);
  ctx.fillRect(x - size*0.42, y - size*0.18, size*0.84, aw);
  ctx.restore();
}

function drawIslam_OLD(ctx, x, y, size) {
  // Render onto a temp canvas so destination-out compositing doesn't affect other content
  const dim = Math.ceil(size * 2.2);
  const tmp = document.createElement('canvas');
  tmp.width = tmp.height = dim;
  const tc = tmp.getContext('2d');
  const cx = dim / 2, cy = dim / 2;

  const ro = size * 0.58;
  const ri = size * 0.46;
  const od = size * 0.22;  // inner circle offset right — creates crescent opening on right

  // Outer circle (solid black)
  tc.fillStyle = '#111';
  tc.beginPath();
  tc.arc(cx, cy, ro, 0, Math.PI * 2);
  tc.fill();

  // Cut out inner circle to form crescent
  tc.globalCompositeOperation = 'destination-out';
  tc.beginPath();
  tc.arc(cx + od, cy, ri, 0, Math.PI * 2);
  tc.fill();

  // Star in the crescent opening (right side, slightly above center)
  tc.globalCompositeOperation = 'source-over';
  tc.fillStyle = '#111';
  const starCX = cx + size * 0.28;
  const starCY = cy - size * 0.10;
  const starR  = size * 0.19;
  const starIR = starR * 0.42;
  tc.beginPath();
  for (let i = 0; i < 10; i++) {
    const angle = (i * Math.PI / 5) - Math.PI / 2;
    const r = i % 2 === 0 ? starR : starIR;
    const sx = starCX + Math.cos(angle) * r;
    const sy = starCY + Math.sin(angle) * r;
    if (i === 0) tc.moveTo(sx, sy); else tc.lineTo(sx, sy);
  }
  tc.closePath();
  tc.fill();

  ctx.save();
  ctx.drawImage(tmp, x - dim / 2, y - dim / 2);
  ctx.restore();
}

function drawBuddhism_OLD(ctx, x, y, size) {
  // Seated Buddha — black outline, clear interior
  ctx.save();
  ctx.strokeStyle = '#111'; ctx.lineWidth = 1.4; ctx.lineCap = 'round'; ctx.lineJoin = 'round';

  // Topknot
  ctx.beginPath(); ctx.ellipse(x, y - size*0.62, size*0.08, size*0.1, 0, 0, Math.PI*2); ctx.stroke();
  // Head
  ctx.beginPath(); ctx.arc(x, y - size*0.42, size*0.17, 0, Math.PI*2); ctx.stroke();
  // Neck
  ctx.beginPath(); ctx.moveTo(x - size*0.07, y - size*0.25); ctx.lineTo(x + size*0.07, y - size*0.25); ctx.stroke();
  // Robe body (wide inverted trapezoid)
  ctx.beginPath();
  ctx.moveTo(x - size*0.1, y - size*0.22);
  ctx.lineTo(x - size*0.46, y + size*0.38);
  ctx.lineTo(x + size*0.46, y + size*0.38);
  ctx.lineTo(x + size*0.1, y - size*0.22);
  ctx.closePath(); ctx.stroke();
  // Hands in lap (meditation mudra)
  ctx.beginPath();
  ctx.ellipse(x, y + size*0.1, size*0.19, size*0.09, 0, 0, Math.PI*2); ctx.stroke();
  // Lotus legs
  ctx.beginPath();
  ctx.moveTo(x - size*0.46, y + size*0.38);
  ctx.bezierCurveTo(x - size*0.55, y + size*0.5, x - size*0.22, y + size*0.58, x, y + size*0.58);
  ctx.bezierCurveTo(x + size*0.22, y + size*0.58, x + size*0.55, y + size*0.5, x + size*0.46, y + size*0.38);
  ctx.stroke();

  ctx.restore();
}

function drawHinduism_OLD(ctx, x, y, size) {
  // Hindu mandala — concentric rings with petals and radial lines
  ctx.save();
  ctx.strokeStyle = '#111'; ctx.lineCap = 'round';

  // Outer ring
  ctx.lineWidth = 1.4;
  ctx.beginPath(); ctx.arc(x, y, size*0.58, 0, Math.PI*2); ctx.stroke();
  // Middle ring
  ctx.lineWidth = 1.0;
  ctx.beginPath(); ctx.arc(x, y, size*0.36, 0, Math.PI*2); ctx.stroke();
  // Inner ring
  ctx.beginPath(); ctx.arc(x, y, size*0.15, 0, Math.PI*2); ctx.stroke();

  // 8 petals between inner and middle ring
  for (let i = 0; i < 8; i++) {
    const a = (i / 8) * Math.PI * 2;
    ctx.beginPath();
    ctx.ellipse(x + Math.cos(a)*size*0.255, y + Math.sin(a)*size*0.255,
                size*0.08, size*0.12, a, 0, Math.PI*2);
    ctx.stroke();
  }

  // 8 radial spokes from middle to outer (offset by half step)
  ctx.lineWidth = 0.9;
  for (let i = 0; i < 8; i++) {
    const a = (i / 8) * Math.PI * 2 + Math.PI/8;
    ctx.beginPath();
    ctx.moveTo(x + Math.cos(a)*size*0.36, y + Math.sin(a)*size*0.36);
    ctx.lineTo(x + Math.cos(a)*size*0.58, y + Math.sin(a)*size*0.58);
    ctx.stroke();
  }

  // Center dot
  ctx.fillStyle = '#111';
  ctx.beginPath(); ctx.arc(x, y, size*0.05, 0, Math.PI*2); ctx.fill();

  ctx.restore();
}

