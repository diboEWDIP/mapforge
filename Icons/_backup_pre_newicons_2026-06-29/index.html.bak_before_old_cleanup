function drawRice_OLD(ctx, x, y, size) {
  ctx.save();
  ctx.strokeStyle = '#111'; ctx.lineCap = 'round';
  const baseX = x-size*0.08, baseY = y+size*0.55, topX = x+size*0.05, topY = y-size*0.28;
  ctx.lineWidth = 1.5;
  ctx.beginPath(); ctx.moveTo(baseX, baseY); ctx.quadraticCurveTo(x-size*0.05, y+size*0.1, topX, topY); ctx.stroke();
  ctx.lineWidth = 1;
  ctx.beginPath(); ctx.moveTo(x-size*0.04, y+size*0.18); ctx.quadraticCurveTo(x-size*0.38, y-size*0.08, x-size*0.42, y+size*0.02); ctx.stroke();
  const hEx = x+size*0.52, hEy = y+size*0.08;
  ctx.lineWidth = 1.4;
  ctx.beginPath(); ctx.moveTo(topX, topY); ctx.quadraticCurveTo(x+size*0.42, topY, hEx, hEy); ctx.stroke();
  const grainCount = 7;
  for (let i = 0; i < grainCount; i++) {
    const t = i/(grainCount-1), gx = topX+(hEx-topX)*t, gy = topY+(hEy-topY)*t*t;
    const len = size*(0.1+Math.sin(t*Math.PI)*0.09);
    ctx.lineWidth = 0.9;
    ctx.beginPath(); ctx.moveTo(gx,gy); ctx.lineTo(gx+size*0.02, gy+len); ctx.stroke();
    ctx.beginPath(); ctx.ellipse(gx+size*0.02, gy+len+size*0.055, size*0.038, size*0.065, 0.15, 0, Math.PI*2); ctx.stroke();
  }
  ctx.restore();
}

