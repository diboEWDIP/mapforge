    const d = id.data;
    for (let i = 0; i < d.length; i += 4) {
      const lum = 0.299 * d[i] + 0.587 * d[i+1] + 0.114 * d[i+2];
      if (lum > 210) {
        d[i+3] = 0;
      } else {
        d[i+3] = Math.min(255, Math.round((255 - lum) * 1.6));
        d[i] = 0; d[i+1] = 0; d[i+2] = 0;
      }
