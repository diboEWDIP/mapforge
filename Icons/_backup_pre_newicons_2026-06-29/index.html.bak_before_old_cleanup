function drawNavalStores_OLD(ctx, x, y, size) {
  ctx.save();
  ctx.strokeStyle = '#111'; ctx.lineCap = 'round'; ctx.lineJoin = 'round';
  const bw = size*0.5, bh = size*0.72;
  const ty = y - bh/2, by = y + bh/2;

  // Left and right curved stave edges
  ctx.lineWidth = 1.5;
  ctx.beginPath();
  ctx.moveTo(x - bw/2, ty);
  ctx.bezierCurveTo(x - bw*0.78, y - bh*0.12, x - bw*0.78, y + bh*0.12, x - bw/2, by);
  ctx.stroke();
  ctx.beginPath();
  ctx.moveTo(x + bw/2, ty);
  ctx.bezierCurveTo(x + bw*0.78, y - bh*0.12, x + bw*0.78, y + bh*0.12, x + bw/2, by);
  ctx.stroke();
  // Top and bottom flat edges
  ctx.beginPath(); ctx.moveTo(x - bw/2, ty); ctx.lineTo(x + bw/2, ty); ctx.stroke();
  ctx.beginPath(); ctx.moveTo(x - bw/2, by); ctx.lineTo(x + bw/2, by); ctx.stroke();
  // Top ellipse
  ctx.beginPath(); ctx.ellipse(x, ty, bw/2, bh*0.11, 0, 0, Math.PI*2); ctx.stroke();

  // 3 horizontal hoops
  ctx.lineWidth = 2;
  [-0.3, 0, 0.3].forEach(t => {
    const hy = y + t * bh * 0.6;
    const tRel = (hy - ty) / bh;
    const hw = bw/2 * (1 + 0.28 * Math.sin(Math.PI * tRel));
    ctx.beginPath(); ctx.moveTo(x - hw, hy); ctx.lineTo(x + hw, hy); ctx.stroke();
  });

  // Vertical stave lines — 4 inner lines following barrel curve
  ctx.lineWidth = 0.85;
  [-0.55, -0.2, 0.2, 0.55].forEach(tx => {
    ctx.beginPath();
    ctx.moveTo(x + tx * bw/2, ty);
    ctx.quadraticCurveTo(x + tx * bw/2 * 1.3, y, x + tx * bw/2, by);
    ctx.stroke();
  });
  ctx.restore();
}

function drawTobacco_OLD(ctx, x, y, size) {
  ctx.save();
  ctx.strokeStyle = '#111'; ctx.lineCap = 'round'; ctx.lineJoin = 'round';
  // Leaf outline — broad ovate
  ctx.lineWidth = 1.6;
  ctx.beginPath();
  ctx.moveTo(x, y + size*0.65);
  ctx.quadraticCurveTo(x - size*0.62, y + size*0.25, x - size*0.68, y - size*0.08);
  ctx.quadraticCurveTo(x - size*0.52, y - size*0.58, x, y - size*0.68);
  ctx.quadraticCurveTo(x + size*0.52, y - size*0.58, x + size*0.68, y - size*0.08);
  ctx.quadraticCurveTo(x + size*0.62, y + size*0.25, x, y + size*0.65);
  ctx.stroke();
  // Midrib
  ctx.beginPath(); ctx.moveTo(x, y + size*0.65); ctx.lineTo(x, y - size*0.68); ctx.stroke();
  // Lateral veins
  ctx.lineWidth = 0.9;
  [[-0.62, 0.1], [-0.55, -0.25], [-0.35, -0.5],
   [ 0.62, 0.1], [ 0.55, -0.25], [ 0.35, -0.5]].forEach(([vx, vy]) => {
    ctx.beginPath(); ctx.moveTo(x, y + vy*size);
    ctx.lineTo(x + vx*size, y + vy*size - size*0.06); ctx.stroke();
  });
  ctx.restore();
}

function drawCotton_OLD(ctx, x, y, size) {
  ctx.save();
  ctx.strokeStyle = '#111'; ctx.lineCap = 'round';

  // Stem
  ctx.lineWidth = 1.5;
  ctx.beginPath(); ctx.moveTo(x, y + size*0.65); ctx.lineTo(x, y + size*0.18); ctx.stroke();

  // 3 solid black pointed sepals at the boll base (side view — fan outward from stem top)
  ctx.fillStyle = '#111';
  [[-0.42, 0.18], [0, -0.04], [0.42, 0.18]].forEach(([sx, sy]) => {
    ctx.beginPath();
    ctx.moveTo(x - size*0.08, y + size*0.22);
    ctx.lineTo(x + sx*size, y + sy*size);
    ctx.lineTo(x + size*0.08, y + size*0.22);
    ctx.closePath(); ctx.fill();
  });

  // White cotton puff — cluster of overlapping circles forming a rounded boll (side view)
  ctx.fillStyle = '#fff'; ctx.lineWidth = 1.1;
  [[-0.14,-0.28],[0.14,-0.28],[0,-0.42],[0.22,-0.15],[-0.22,-0.15],[0,-0.18]].forEach(([bx,by]) => {
    ctx.beginPath(); ctx.arc(x+bx*size, y+by*size, size*0.16, 0, Math.PI*2);
    ctx.fill(); ctx.stroke();
  });
  ctx.restore();
}

function drawDyes_OLD(ctx, x, y, size) {
  // Three classic water drops: pointed top, round bottom, black outline, clear interior
  ctx.save();
  ctx.strokeStyle = '#111'; ctx.lineWidth = 1.5; ctx.lineCap = 'round';

  function waterDrop(cx, cy, s) {
    ctx.beginPath();
    ctx.moveTo(cx, cy - s*0.52);
    ctx.bezierCurveTo(cx + s*0.44, cy - s*0.1, cx + s*0.44, cy + s*0.28, cx, cy + s*0.52);
    ctx.bezierCurveTo(cx - s*0.44, cy + s*0.28, cx - s*0.44, cy - s*0.1, cx, cy - s*0.52);
    ctx.closePath(); ctx.stroke();
  }

  // Three drops: top-center, bottom-left, bottom-right
  waterDrop(x,              y - size*0.22, size*0.36);
  waterDrop(x - size*0.34,  y + size*0.24, size*0.34);
  waterDrop(x + size*0.34,  y + size*0.24, size*0.34);

  ctx.restore();
}

function drawSugar_OLD(ctx, x, y, size) {
  ctx.save();
  ctx.strokeStyle = '#111'; ctx.lineWidth = 1.4;
  function miniCube(cx, cy, s) {
    const fw=s, fh=s*0.62, dx=s*0.32, dy=s*0.22;
    ctx.fillStyle='#ccc';
    ctx.beginPath();
    ctx.moveTo(cx+fw/2,cy-fh/2); ctx.lineTo(cx+fw/2+dx,cy-fh/2-dy);
    ctx.lineTo(cx+fw/2+dx,cy+fh/2-dy); ctx.lineTo(cx+fw/2,cy+fh/2);
    ctx.closePath(); ctx.fill(); ctx.stroke();
    ctx.fillStyle='#eee';
    ctx.beginPath();
    ctx.moveTo(cx-fw/2,cy-fh/2); ctx.lineTo(cx-fw/2+dx,cy-fh/2-dy);
    ctx.lineTo(cx+fw/2+dx,cy-fh/2-dy); ctx.lineTo(cx+fw/2,cy-fh/2);
    ctx.closePath(); ctx.fill(); ctx.stroke();
    ctx.fillStyle='#fff';
    ctx.fillRect(cx-fw/2,cy-fh/2,fw,fh); ctx.strokeRect(cx-fw/2,cy-fh/2,fw,fh);
  }
  const s = size*0.46;
  miniCube(x - size*0.28, y + size*0.18, s);
  miniCube(x + size*0.28, y + size*0.18, s);
  miniCube(x,             y - size*0.18, s);
  ctx.restore();
}

function drawIndigo_OLD(ctx, x, y, size) {
  // Iris side view: stem, leaf, 3 upright petals + 2 drooping falls — petals filled blue
  ctx.save();
  ctx.strokeStyle = '#111'; ctx.lineCap = 'round'; ctx.lineJoin = 'round';

  // Stem
  ctx.lineWidth = 1.4;
  ctx.beginPath(); ctx.moveTo(x, y + size*0.68); ctx.lineTo(x, y - size*0.05); ctx.stroke();

  // Leaf
  ctx.lineWidth = 1;
  ctx.beginPath();
  ctx.moveTo(x, y + size*0.3);
  ctx.quadraticCurveTo(x + size*0.42, y + size*0.08, x + size*0.44, y + size*0.34);
  ctx.quadraticCurveTo(x + size*0.26, y + size*0.42, x, y + size*0.3);
  ctx.stroke();

  ctx.fillStyle = '#2244cc';
  ctx.lineWidth = 1.3;

  // 3 upright standard petals — blue filled ellipses
  [[-0.14, -0.52, -0.25], [0, -0.6, 0], [0.14, -0.52, 0.25]].forEach(([ox, oy, rot]) => {
    ctx.beginPath();
    ctx.ellipse(x + ox*size, y + oy*size, size*0.1, size*0.2, rot, 0, Math.PI*2);
    ctx.fill(); ctx.stroke();
  });

  // 2 drooping falls — tilted ellipses spreading down and outward
  [[-0.28, -0.1, -0.65], [0.28, -0.1, 0.65]].forEach(([ox, oy, rot]) => {
    ctx.beginPath();
    ctx.ellipse(x + ox*size, y + oy*size, size*0.1, size*0.22, rot, 0, Math.PI*2);
    ctx.fill(); ctx.stroke();
  });

  // White center
  ctx.fillStyle = '#fff';
  ctx.beginPath(); ctx.arc(x, y - size*0.05, size*0.07, 0, Math.PI*2);
  ctx.fill(); ctx.stroke();

  ctx.restore();
}

function drawFurs_OLD(ctx, x, y, size) {
  // Solid black beaver — side profile
  ctx.save();
  ctx.fillStyle = '#111';

  // Main body — large round oval, slightly lowered
  ctx.beginPath();
